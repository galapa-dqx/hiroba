# OpenAI API key for image localization and event extraction
OPENAI_API_KEY=sk-...

# Gemini API key for image transcription and translation
GEMINI_API_KEY=...

# Workflow log verbosity: debug | info | warn | error | silent (default info).
# Local dev loads this via dotenv; deployed default lives in apps/workflow/wrangler.toml.
LOG_LEVEL=debug
