{
  "name": "hiroba",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "deploy": "turbo deploy",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "lint": "turbo lint",
    "fallow": "fallow",
    "fallow:dead": "fallow dead-code",
    "fallow:watch": "fallow watch",
    "db:setup": "mkdir -p .wrangler-shared/v3/d1 && pnpm db:migrate:local",
    "db:migrate:local": "wrangler d1 migrations apply DB --local --persist-to .wrangler-shared --config apps/workflow/wrangler.toml",
    "db:migrate:prod": "wrangler d1 migrations apply DB --remote --config apps/workflow/wrangler.toml"
  },
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "@ianvs/prettier-plugin-sort-imports": "^4.4.0",
    "@vitest/eslint-plugin": "^1.3.9",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-import-resolver-typescript": "^4.4.0",
    "eslint-plugin-import-x": "^4.6.1",
    "fallow": "^3.4.2",
    "fetch-mock": "^12.5.2",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "turbo": "^2.10.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.18.2",
    "vitest": "^4.1.10",
    "wrangler": "^4.111.0"
  },
  "packageManager": "pnpm@11.13.1+sha512.b2fc7683b8a6525414e7d13e1ba28caaddde96bf66ec540bfaeb7e702b81f3e0be4d1f295edf7f9fe0396740a8dce4509c582ddf79891f4543fea32d37645f25",
  "engines": {
    "node": ">=22.15.0"
  }
}
