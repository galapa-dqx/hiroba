---
import Layout from "../../layouts/Layout.astro";
import ImagesList from "../../components/ImagesList";
---

<Layout title="Images">
	<p class="page-description">
		Every image the pipeline has stored, beside its translated equivalent in the
		primary target language (set at the bottom of the sidebar). A localized
		image appears once its text is translated and baked in; until then the row
		shows the pipeline step it's currently on.
	</p>
	<ImagesList client:load />
</Layout>
