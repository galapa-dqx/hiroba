---
import Rosette from "@hiroba/ui/Rosette.astro";
import ThemeToggle from "@hiroba/ui/ThemeToggle.astro";
import PrimaryLanguageSelect from "../components/PrimaryLanguageSelect";
import "@hiroba/ui/styles/palette.css";
import "@hiroba/ui/styles/article-body.css";
import "../styles/admin.css";

interface Props {
	title: string;
}

const { title } = Astro.props;

const nav = [
	{ href: "/", label: "Dashboard" },
	{ href: "/news", label: "News" },
	{ href: "/topics", label: "Topics" },
	{ href: "/playguide", label: "Play Guide" },
	{ href: "/images", label: "Images" },
	{ href: "/workflows", label: "Workflows" },
	{ href: "/events", label: "Events" },
	{ href: "/resets", label: "Resets" },
	{ href: "/recheck-queue", label: "Recheck Queue" },
	{ href: "/glossary", label: "Glossary" },
	{ href: "/languages", label: "Languages" },
];

const pathname = Astro.url.pathname;
const isActive = (href: string) =>
	href === "/" ? pathname === "/" : pathname === href || pathname.startsWith(`${href}/`);
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="robots" content="noindex, nofollow" />
		<meta name="color-scheme" content="light dark" />
		<title>{title} | Galapa Admin</title>
		<script is:inline>
			(() => {
				try {
					const t = localStorage.getItem("dqx-theme");
					if (t === "dark" || t === "light") document.documentElement.dataset.theme = t;
				} catch (_) {}
			})();
		</script>
	</head>
	<body>
		<nav class="sidebar">
			<a href="/" class="brand" aria-label="Galapa Admin — dashboard">
				<Rosette class="brand__mark" />
				<span class="brand__word">Galapa&nbsp;<em>Admin</em></span>
			</a>
			<ul>
				{
					nav.map((item) => (
						<li>
							<a href={item.href} aria-current={isActive(item.href) ? "page" : undefined}>
								{item.label}
							</a>
						</li>
					))
				}
			</ul>
			<div class="sidebar__foot">
				<PrimaryLanguageSelect client:load />
				<div class="sidebar__foot-row">
					<span>Keeper's console</span>
					<ThemeToggle />
				</div>
			</div>
		</nav>
		<main>
			<header class="page-header">
				<h2>{title}</h2>
			</header>
			<div class="content">
				<slot />
			</div>
		</main>
	</body>
</html>
