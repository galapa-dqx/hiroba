{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "hiroba-admin",
  // Astro 6 / @astrojs/cloudflare v13 ships a Worker (Pages support dropped).
  // The adapter's entrypoint serves SSR + the static assets bound below.
  "main": "@astrojs/cloudflare/entrypoints/server",
  "compatibility_date": "2026-07-08",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
  },
  // Workers Logs + automatic traces, persisted to the CF dashboard (7-day
  // retention, query builder). Wrangler config is the source of truth here —
  // dashboard-only settings get reverted on the next deploy. Low-traffic
  // internal app, so everything is unsampled.
  "observability": {
    "logs": {
      "enabled": true,
      "head_sampling_rate": 1,
      "persist": true,
      "invocation_logs": true,
    },
    "traces": {
      "enabled": true,
      "persist": true,
      "head_sampling_rate": 1,
    },
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "galapa--news-db",
      "database_id": "16dc90f5-02ec-4c06-99b9-179b64b4f200",
    },
  ],
  "r2_buckets": [
    {
      "binding": "IMAGES_BUCKET",
      "bucket_name": "galapa--images",
    },
  ],
  "durable_objects": {
    "bindings": [
      // The flow framework's control plane (DQX-19) — one 'hub' instance
      // holding every flow run; the trigger routes and per-run SSE streams
      // talk to it directly.
      {
        "name": "FLOW_HUB",
        "class_name": "FlowHub",
        "script_name": "hiroba-workflow",
      },
    ],
  },
  // The workflow worker's plain routes (DQX-26): the per-item SSE progress
  // streams, the enriched tracker listing, and single-image regeneration
  // (the workflow worker holds the OpenAI key + Images binding this app lacks).
  "services": [
    {
      "binding": "WORKFLOW",
      "service": "hiroba-workflow",
    },
  ],
}
