{
  "name": "@hiroba/workflow",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "deploy": "wrangler deploy",
    "dev": "CLOUDFLARE_INCLUDE_PROCESS_ENV=true dotenv -e ../../.env -- wrangler dev --test-scheduled --persist-to ../../.wrangler-shared",
    "start": "wrangler dev --persist-to ../../.wrangler-shared",
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run -c vitest.unit.config.ts && vitest run -c vitest.workers.config.ts",
    "test:watch": "vitest -c vitest.unit.config.ts"
  },
  "dependencies": {
    "@google/genai": "^2.11.0",
    "@hiroba/db": "workspace:*",
    "@hiroba/flow": "workspace:*",
    "@hiroba/flows": "workspace:*",
    "@hiroba/richtext": "workspace:*",
    "@hiroba/scraper": "workspace:*",
    "@hiroba/shared": "workspace:*",
    "@sentry/cloudflare": "^10.34.0",
    "csv-parse": "^6.1.0",
    "drizzle-orm": "1.0.0-beta.6-cd45bda",
    "fast-png": "^8.0.0",
    "openai": "^5.5.0",
    "temporal-polyfill": "^0.3.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.18.4",
    "@cloudflare/workers-types": "^4.20250507.0",
    "drizzle-kit": "1.0.0-beta.6-cd45bda",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0",
    "wrangler": "^4.54.0"
  }
}
