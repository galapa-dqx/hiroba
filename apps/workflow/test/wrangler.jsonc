// Test-only worker config for the pool-workers integration tier. Mirrors the
// production mount (wrangler.toml): the FLOW_HUB DO plus the banner workflow
// binding. DB/R2/keys exist only so the worker boots — every step body is
// mocked through the introspector, so none of them is ever touched.
{
  "name": "workflow-test",
  "main": "./fixtures/worker.ts",
  "compatibility_date": "2025-11-21",
  "compatibility_flags": ["nodejs_compat"],
  "durable_objects": {
    "bindings": [{ "name": "FLOW_HUB", "class_name": "FlowHub" }],
  },
  "migrations": [{ "tag": "v1", "new_sqlite_classes": ["FlowHub"] }],
  "workflows": [
    {
      "name": "banner-workflow",
      "binding": "BANNER_WORKFLOW",
      "class_name": "BannerWorkflow",
    },
    {
      "name": "glossary-regenerate-workflow",
      "binding": "GLOSSARY_REGENERATE_WORKFLOW",
      "class_name": "GlossaryRegenerateWorkflow",
    },
    {
      "name": "title-workflow",
      "binding": "TITLE_WORKFLOW",
      "class_name": "TitleWorkflow",
    },
    {
      "name": "title-backfill-workflow",
      "binding": "TITLE_BACKFILL_WORKFLOW",
      "class_name": "TitleBackfillWorkflow",
    },
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "test-db",
      "database_id": "workflow-test-db",
    },
  ],
  "r2_buckets": [{ "binding": "IMAGES_BUCKET", "bucket_name": "test-images" }],
  "vars": {
    "GEMINI_API_KEY": "test-key",
    "OPENAI_API_KEY": "test-key",
    "LOG_LEVEL": "silent",
  },
}
