---
import { CATEGORIES, CATEGORY_LABELS, type Category } from "@hiroba/shared";
import Rosette from "@hiroba/ui/Rosette.astro";
import Ornament from "@hiroba/ui/Ornament.astro";
import ThemeToggle from "@hiroba/ui/ThemeToggle.astro";
import "@hiroba/ui/styles/palette.css";
import "../styles/global.css";

interface Props {
	title: string;
	/** Highlights the matching nav tab (article + category pages pass this). */
	category?: Category;
	/** Absolute canonical URL. Defaults to this page's own URL. Article pages
	 *  point it at the Hiroba original so we defer to the source in search
	 *  rather than competing with it for the same content. */
	canonical?: string;
	/** hreflang language alternates, emitted as <link rel="alternate">.
	 *  Defaults to this page's own path in every enabled language. */
	alternates?: { hreflang: string; href: string }[];
}

const { title, category, canonical, alternates } = Astro.props;

// Set by the middleware, which validated the /<lang>/ prefix against the
// admin-managed whitelist.
const lang = Astro.locals.lang ?? "en";
const languages = Astro.locals.languages ?? [
	{ code: "en", label: "English", nativeLabel: "English" },
];
const base = `/${lang}`;

const pathname = Astro.url.pathname;
// The language-independent remainder of the path ('' on the home page).
const pathAfterLang = pathname.startsWith(base)
	? pathname.slice(base.length).replace(/^\/$/, "")
	: pathname;

// Fall back to deriving the active category from the URL (/<lang>/category/<slug>).
const active =
	category ??
	(CATEGORIES.find((c) => pathAfterLang.startsWith(`/category/${c}`)) as Category | undefined);

// Self-referential by default (query/hash dropped); overridden per-page.
const canonicalUrl = canonical ?? new URL(pathname, Astro.url.origin).href;

// Mirror pages: unless the page supplied its own alternates (articles do),
// declare this path in every enabled language.
const alternateLinks =
	alternates ??
	(languages.length > 1
		? languages.map((l) => ({
				hreflang: l.code,
				href: new URL(`/${l.code}${pathAfterLang}`, Astro.url.origin).href,
			}))
		: []);
---

<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="description" content="Dragon Quest X news, translated from the official Hiroba" />
		<meta name="color-scheme" content="light dark" />
		<link rel="canonical" href={canonicalUrl} />
		{alternateLinks.map((a) => <link rel="alternate" hreflang={a.hreflang} href={a.href} />)}
		<title>{title} | Galapa News</title>
		{/* Apply the saved theme before first paint to avoid a flash. */}
		<script is:inline>
			(() => {
				try {
					const t = localStorage.getItem("dqx-theme");
					if (t === "dark" || t === "light") document.documentElement.dataset.theme = t;
				} catch (_) {}
			})();
		</script>
	</head>
	<body>
		<header class="site-header">
			<div class="site-header__inner">
				<a href={base} class="brand" aria-label="Galapa News — home">
					<Rosette class="brand__mark" />
					<span class="brand__word">Galapa&nbsp;<em>News</em></span>
				</a>
				<nav class="nav" aria-label="Primary">
					{/* News categories, folded into one disclosure so the header stays
					    roomy as sections grow. Open when on any category page. */}
					<details class="nav-menu nav-menu--start">
						<summary aria-current={active ? "page" : undefined}>News</summary>
						<ul>
							{
								CATEGORIES.map((c) => (
									<li>
										<a
											data-cat={c}
											href={`${base}/category/${c}`}
											aria-current={active === c ? "page" : undefined}
										>
											{CATEGORY_LABELS[c]}
										</a>
									</li>
								))
							}
						</ul>
					</details>
					<a
						class="nav__link"
						href={`${base}/topics`}
						aria-current={pathAfterLang.startsWith("/topics") ? "page" : undefined}
					>
						Topics
					</a>
					<a
						class="nav__link"
						href={`${base}/playguide`}
						aria-current={pathAfterLang.startsWith("/playguide") ? "page" : undefined}
					>
						Play Guide
					</a>
					{
						languages.length > 1 && (
							<details class="nav-menu nav-menu--end">
								<summary aria-label="Change language">
									<span aria-hidden="true">🌐</span>
									{languages.find((l) => l.code === lang)?.nativeLabel ?? lang}
								</summary>
								<ul>
									{languages.map((l) => (
										<li>
											<a
												href={`/${l.code}${pathAfterLang}${Astro.url.search}`}
												lang={l.code}
												hreflang={l.code}
												aria-current={l.code === lang ? "page" : undefined}
											>
												{l.nativeLabel}
											</a>
										</li>
									))}
								</ul>
							</details>
						)
					}
					<ThemeToggle />
				</nav>
			</div>
		</header>

		<main>
			<slot />
		</main>

		<footer class="site-footer">
			<Ornament />
			<p>
				Translated from <a href="https://hiroba.dqx.jp" target="_blank" rel="noopener"
					>DQX Hiroba</a
				> — a fan project, not affiliated with Square Enix.
			</p>
		</footer>

		<style>
			/* Header dropdowns — a quiet disclosure styled to match the nav
			   links, shared by the News-category menu and the language switcher. */
			.nav-menu {
				position: relative;
			}
			.nav-menu > summary {
				list-style: none;
				cursor: pointer;
				padding: 0.4rem 0.7rem;
				font-size: 0.92rem;
				font-weight: 600;
				color: var(--ink-soft);
				border-radius: var(--radius-sm);
				display: inline-flex;
				align-items: center;
				gap: 0.35rem;
				white-space: nowrap;
				transition:
					color 0.15s ease,
					background 0.15s ease;
			}
			.nav-menu > summary::-webkit-details-marker {
				display: none;
			}
			/* Disclosure caret — a small chevron that flips when the menu opens. */
			.nav-menu > summary::after {
				content: "";
				width: 0.42em;
				height: 0.42em;
				margin-left: 0.05em;
				border-right: 1.5px solid currentColor;
				border-bottom: 1.5px solid currentColor;
				transform: translateY(-0.12em) rotate(45deg);
				opacity: 0.55;
				transition: transform 0.18s ease;
			}
			.nav-menu[open] > summary::after {
				transform: translateY(0.05em) rotate(225deg);
			}
			.nav-menu > summary:hover,
			.nav-menu > summary[aria-current="page"] {
				color: var(--ink);
				background: var(--surface-hover);
			}
			.nav-menu > ul {
				position: absolute;
				margin: 0.25rem 0 0;
				padding: 0.3rem;
				list-style: none;
				min-width: 9rem;
				background: var(--surface-panel);
				border: 1px solid var(--rule-strong);
				box-shadow: var(--shadow-sm);
				z-index: 60;
			}
			.nav-menu--start > ul {
				left: 0;
			}
			.nav-menu--end > ul {
				right: 0;
			}
			.nav-menu li a {
				display: flex;
				align-items: center;
				gap: 0.5rem;
				padding: 0.35rem 0.6rem;
				font-size: 0.92rem;
				font-weight: 600;
				color: var(--ink-soft);
				text-decoration: none;
				border-radius: var(--radius-sm);
				white-space: nowrap;
			}
			.nav-menu li a:hover,
			.nav-menu li a[aria-current="page"] {
				color: var(--gold-edge);
				background: var(--surface-hover);
			}
			/* Preserve each news category's colour identity as a leading dot. */
			.nav-menu li a[data-cat]::before {
				content: "";
				flex: none;
				width: 0.5rem;
				height: 0.5rem;
				border-radius: 50%;
				background: var(--cat, var(--accent));
			}
			.nav-menu li a[data-cat="news"] {
				--cat: var(--blue-9);
			}
			.nav-menu li a[data-cat="event"] {
				--cat: var(--purple-9);
			}
			.nav-menu li a[data-cat="update"] {
				--cat: var(--green-9);
			}
			.nav-menu li a[data-cat="maintenance"] {
				--cat: var(--red-9);
			}
		</style>
		<script>
			// One header dropdown open at a time; close on outside click.
			const menus = document.querySelectorAll<HTMLDetailsElement>(".nav-menu");
			menus.forEach((menu) => {
				menu.addEventListener("toggle", () => {
					if (menu.open) menus.forEach((m) => m !== menu && (m.open = false));
				});
				document.addEventListener("click", (e) => {
					if (menu.open && e.target instanceof Node && !menu.contains(e.target)) {
						menu.open = false;
					}
				});
			});
		</script>
	</body>
</html>
