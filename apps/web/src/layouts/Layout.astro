---
import { CATEGORIES, CATEGORY_LABELS, type Category } from "@hiroba/shared";
import Rosette from "@hiroba/ui/Rosette.astro";
import Ornament from "@hiroba/ui/Ornament.astro";
import ThemeToggle from "@hiroba/ui/ThemeToggle.astro";
import "@hiroba/ui/styles/palette.css";
import "../styles/global.css";

interface Props {
	title: string;
	/** Highlights the matching nav tab (article + category pages pass this). */
	category?: Category;
}

const { title, category } = Astro.props;

// Fall back to deriving the active category from the URL (/category/<slug>).
const pathname = Astro.url.pathname;
const active =
	category ??
	(CATEGORIES.find((c) => pathname.startsWith(`/category/${c}`)) as Category | undefined);
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="description" content="Dragon Quest X news, translated to English" />
		<meta name="color-scheme" content="light dark" />
		<title>{title} | DQX News</title>
		{/* Apply the saved theme before first paint to avoid a flash. */}
		<script is:inline>
			(() => {
				try {
					const t = localStorage.getItem("dqx-theme");
					if (t === "dark" || t === "light") document.documentElement.dataset.theme = t;
				} catch (_) {}
			})();
		</script>
	</head>
	<body>
		<header class="site-header">
			<div class="site-header__inner">
				<a href="/" class="brand" aria-label="DQX News — home">
					<Rosette class="brand__mark" />
					<span class="brand__word">DQX&nbsp;<em>News</em></span>
				</a>
				<nav class="nav" aria-label="Categories">
					{
						CATEGORIES.map((c) => (
							<a
								class="nav__link"
								data-cat={c}
								href={`/category/${c}`}
								aria-current={active === c ? "page" : undefined}
							>
								{CATEGORY_LABELS[c]}
							</a>
						))
					}
					<a
						class="nav__link"
						href="/topics"
						aria-current={pathname.startsWith("/topics") ? "page" : undefined}
					>
						Topics
					</a>
					<ThemeToggle />
				</nav>
			</div>
		</header>

		<main>
			<slot />
		</main>

		<footer class="site-footer">
			<Ornament />
			<p>
				Translated from <a href="https://hiroba.dqx.jp" target="_blank" rel="noopener"
					>DQX Hiroba</a
				> — a fan project, not affiliated with Square Enix.
			</p>
		</footer>
	</body>
</html>
