---
/**
 * ArticlePage — the shared shell of the news and topic detail pages: header
 * (meta line + title), processing callout with live run progress, the article
 * body beside its events rail, the translation footer, and the back link.
 *
 * The pages differ only in how they load their data; everything rendered runs
 * through here. The body displays only once the pipeline has settled
 * (`view.ready`) — until then the callout narrates the item's hub run
 * (DQX-28): the initial line renders server-side from the run snapshot, and
 * the client follows the run's SSE stream for progress updates and the
 * reload on completion.
 */
import type { EventWithTitle } from "@hiroba/db";
import type { Snapshot } from "@hiroba/flow";
import { describeItemRun, itemFlowKey } from "@hiroba/flows";
import type { Category } from "@hiroba/shared";
import Rosette from "@hiroba/ui/Rosette.astro";
import Ornament from "@hiroba/ui/Ornament.astro";
import Layout from "../layouts/Layout.astro";
import BackLink from "./BackLink.astro";
import EventsRail from "./EventsRail.astro";
import LocalTime from "./LocalTime.astro";
import type { ArticleView } from "../lib/article-view";
import { itemRunStrings, useTranslations } from "../i18n";
import "@hiroba/ui/styles/article-body.css";

interface Props {
	title: string;
	/** News category — themes the shell and highlights the nav tab. Topics omit
	 *  it and fall back to the gilt `topic` identity. */
	category?: Category;
	itemType: "news" | "topic" | "playguide";
	itemId: string;
	/** The render gate's verdict (lib/article-view) for this item + language. */
	view: ArticleView;
	/** The latest run's segment snapshot, when one exists — seeds the initial
	 *  callout line so the first paint matches what the stream will say. */
	snapshot?: Snapshot | null;
	/** The latest run's failure message, surfaced when `view.phase` is
	 *  `run-failed`. */
	runError?: string | null;
	contentHtml: string;
	events: EventWithTitle[];
	/** The source article on hiroba.dqx.jp. */
	originalUrl: string;
	/** When the displayed translation landed (epoch ms) — omitted while raw. */
	translatedAtMs?: number | null;
	backHref: string;
	backLabel: string;
}

const {
	title,
	category,
	itemType,
	itemId,
	view,
	snapshot,
	runError,
	contentHtml,
	events,
	originalUrl,
	translatedAtMs,
	backHref,
	backLabel,
} = Astro.props;

const ready = view.ready;

// Set by the middleware, which validated the /<lang>/ prefix.
const lang = Astro.locals.lang ?? "en";
const languages = Astro.locals.languages ?? [
	{ code: "en", label: "English", nativeLabel: "English" },
];
const t = useTranslations(lang);

// Detail route segment per item type (news uses plural "news", topics
// "topics", playguides "playguide").
const detailPath = itemType === "topic" ? "topics" : itemType === "playguide" ? "playguide" : "news";

// The item's run on the hub, addressed by the flow's dedup key — the client
// follows its snapshot stream while the pipeline is processing.
const { flow, key } = itemFlowKey(itemType, itemId);
const sseUrl = `/api/flow/sse?flow=${encodeURIComponent(flow)}&key=${encodeURIComponent(key)}`;
const originalNoun = t(
	itemType === "topic"
		? "article.noun.topic"
		: itemType === "playguide"
			? "article.noun.guide"
			: "article.noun.article",
);

// Localized copy for the SSE-driven processing callout, handed to the client
// script as JSON: the pipeline status templates plus the terminal lines.
const runStrings = itemRunStrings(lang);
const calloutStrings = {
	...runStrings,
	fetchFailed: t("status.fetchFailed"),
	doneReloading: t("status.doneReloading"),
	errorPrefix: t("status.errorPrefix"),
	unknownError: t("status.unknownError"),
};

// The callout's first paint, derived server-side from the same run the client
// will follow. `processing` narrates the snapshot (or the generic opening
// line while the run is still being created); the two terminal failures show
// their error and don't stream — the pipeline is only re-armed on the
// trigger cooldown, so there is nothing live to watch.
const follow = view.phase === "processing";
const statusText = follow
	? snapshot
		? describeItemRun(snapshot, runStrings)
		: runStrings.fetching
	: view.phase === "fetch-failed"
		? t("status.fetchFailed")
		: t("status.errorPrefix", { error: runError ?? t("status.unknownError") });

// This is a translated republish of the Hiroba original, so we canonicalize to
// the source (cross-domain) rather than compete with it in search. hreflang
// declares the language set: the Japanese source, our rendering in every
// enabled language, and the source as the x-default for unmatched locales.
const alternates = [
	{ hreflang: "ja", href: originalUrl },
	...languages.map((l) => ({
		hreflang: l.code,
		href: new URL(`/${l.code}/${detailPath}/${itemId}`, Astro.url.origin).href,
	})),
	{ hreflang: "x-default", href: originalUrl },
];
---

<Layout title={title} category={category} canonical={originalUrl} alternates={alternates}>
	<article data-cat={category ?? "topic"}>
		<header class="article-header">
			<div class="meta">
				<slot name="meta" />
				<a
					class="meta__source"
					href={originalUrl}
					target="_blank"
					rel="noopener noreferrer">{t("article.viewOriginal", { noun: originalNoun })}</a
				>
			</div>
			<h1 class="article-title">{title}</h1>
		</header>

		{!ready && (
			<div
				class={`callout ${follow ? "callout--busy" : "callout--error"}`}
				id="processing-notice"
				data-sse-url={follow ? sseUrl : undefined}
				data-i18n={JSON.stringify(calloutStrings)}
				role="status"
			>
				<Rosette class="callout__glyph" />
				<p id="processing-status">{statusText}</p>
			</div>
		)}

		{ready && contentHtml && (
			<div class="article-grid">
				<div class="scroll">
					<div class="scroll__content article-body" set:html={contentHtml} />
				</div>
				<EventsRail events={events} />
			</div>
		)}

		<footer class="translation-info">
			<Ornament />
			{translatedAtMs && (
				<p>{t("article.translatedOn")} <LocalTime epochMs={translatedAtMs} mode="date" /></p>
			)}
		</footer>

		<BackLink href={backHref} label={backLabel} />
	</article>
</Layout>

<style>
	.article-header {
		margin-bottom: 1.4rem;
	}
	/* Source link sits on the meta row, pushed to the far right of the chips. */
	.meta__source {
		margin-left: auto;
		display: inline-flex;
		align-items: center;
		font-size: 0.85rem;
		font-weight: 600;
		color: var(--ink-soft);
		text-decoration: none;
		white-space: nowrap;
		transition: color 0.12s ease;
	}
	.meta__source:hover {
		color: var(--gold-edge);
	}
	.article-title {
		font-size: clamp(1.7rem, 1.25rem + 2.4vw, 2.5rem);
		line-height: 1.22;
	}
	.callout {
		margin-bottom: 1.5rem;
	}
	/* article body with the events panel stacked full-width beneath it */
	.article-grid {
		display: grid;
		gap: 1.5rem;
	}
	.translation-info {
		margin-top: 2.4rem;
		text-align: center;
		color: var(--ink-faint);
		font-size: 0.9rem;
	}
	.translation-info p {
		margin: 1rem 0;
	}
</style>

<script>
	import { followRun } from "@hiroba/flow/client";
	import { describeItemRun, itemRunHealth } from "@hiroba/flows";
	import "../scripts/localize-times";

	const notice = document.getElementById("processing-notice");
	if (notice?.dataset.sseUrl) {
		const statusEl = document.getElementById("processing-status");
		// Localized copy embedded by the server (pipeline templates + terminal
		// lines), so the callout speaks the reader's language client-side too.
		const i18n = JSON.parse(notice.dataset.i18n || "{}");

		const showError = (message: string) => {
			notice.classList.remove("callout--busy");
			notice.classList.add("callout--error");
			if (statusEl) statusEl.textContent = message;
		};

		followRun(
			notice.dataset.sseUrl,
			{
				onSnapshot: (snapshot) => {
					if (statusEl) statusEl.textContent = describeItemRun(snapshot, i18n);
				},
				onSettled: (snapshot) => {
					// Same settled policy as the server gate: content landed (even
					// degraded) → the reload paints the body; a dead end shows why.
					const health = itemRunHealth(snapshot);
					if (health === "complete" || health === "degraded") {
						notice.classList.remove("callout--busy");
						notice.classList.add("callout--complete");
						if (statusEl) statusEl.textContent = i18n.doneReloading ?? "Done! Reloading…";
						setTimeout(() => location.reload(), 500);
						return;
					}
					if (health === "fetch-failed") {
						showError(i18n.fetchFailed ?? "Failed to fetch the article.");
						return;
					}
					const template = i18n.errorPrefix ?? "Error: {error}";
					showError(
						template.replace("{error}", snapshot.error || i18n.unknownError || "Unknown error"),
					);
				},
				onUnavailable: () => {
					const template = i18n.errorPrefix ?? "Error: {error}";
					showError(template.replace("{error}", i18n.unknownError || "Unknown error"));
				},
			},
			// The page's fire-and-forget trigger may still be creating the run
			// when we first connect — tolerate a longer 404 window than the
			// admin's follow-a-known-run default.
			{ maxFramelessConnects: 10 },
		);
	}
</script>
