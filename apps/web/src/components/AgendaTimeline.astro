---
/**
 * AgendaTimeline — the vertical 24h axis for one day. Rendered in JST (00:00 at
 * the top, 24:00 at the bottom); the colocated script relabels the hour ticks
 * and bar/mark times to the viewer's zone and drops a "day turnover" line where
 * the viewer's local midnight falls across the JST day.
 *
 *   - bars       rectangles positioned by fraction of the day, packed into
 *                lanes when they overlap; open edges flatten + gain an arrow
 *   - milestones a thin rule + dot at a point in time
 */
import { Temporal } from "temporal-polyfill";
import { AGENDA_ZONE, type BarItem, type MilestoneItem } from "../lib/day-agenda";
import { scheduleInfo, TSUYOSA_URL } from "../lib/schedule";
import { useTranslations } from "../i18n";

interface Props {
	bars: BarItem[];
	/** Dense always-on rotations pulled into their own side columns, by key. */
	swimlanes: Record<string, BarItem[]>;
	milestones: MilestoneItem[];
	day: Temporal.PlainDate;
	lang: string;
}
const { bars, swimlanes, milestones, day, lang } = Astro.props;
const t = useTranslations(lang);

// Fixed order + headers for the reserved side columns (防衛軍・メタルーキー).
const SWIMLANE_META = [
	{ key: "defense", label: t("timeline.swim.defense") },
	{ key: "metal", label: t("timeline.swim.metal") },
];
const lanes = SWIMLANE_META.map((m) => ({ ...m, bars: swimlanes[m.key] ?? [] })).filter(
	(l) => l.bars.length > 0,
);

const dayStart = day.toZonedDateTime(AGENDA_ZONE);
const dayStartMs = dayStart.toInstant().epochMilliseconds;

// Hour labels every 3h, including the closing 24:00.
const TICK_STEP = 3;
const ticks = Array.from({ length: 24 / TICK_STEP + 1 }, (_, i) => {
	const hour = i * TICK_STEP;
	const at = dayStart.add({ hours: hour });
	return {
		hour,
		topPct: (hour / 24) * 100,
		iso: at.toInstant().toString(),
		label: `${String(hour % 24).padStart(2, "0")}:00`,
	};
});
// A subtle gridline at every hour; the ones on a label boundary read stronger.
const hourLines = Array.from({ length: 23 }, (_, i) => {
	const hour = i + 1;
	return { topPct: (hour / 24) * 100, major: hour % TICK_STEP === 0 };
});

/** Compact JST wall-clock "HH:MM" for a JST-zoned value. */
const jstTime = (zdt: Temporal.ZonedDateTime): string =>
	zdt.toPlainTime().toString({ smallestUnit: "minute" });

/** Path segment for each article source type ("topic" → the /topics/ route). */
const SOURCE_SEG: Record<string, string> = {
	news: "news",
	topic: "topics",
	playguide: "playguide",
};
/** Link + whether it leaves the site. Schedule events point at the つよさ予報 page. */
function eventLink(e: BarItem["event"]): { href: string | null; external: boolean } {
	if (e.sourceType === "schedule") return { href: TSUYOSA_URL, external: true };
	const seg = e.sourceType ? SOURCE_SEG[e.sourceType] : undefined;
	if (!seg || !e.sourceId) return { href: null, external: false };
	return { href: `/${lang}/${seg}/${e.sourceId}`, external: false };
}

const empty =
	bars.length === 0 && milestones.length === 0 && lanes.length === 0;
---

<div class="agenda-tl" style={`--swim-count:${lanes.length}`}>
	{/* Header row: a label per side column (placed explicitly). */}
	{lanes.map((l, i) => (
		<div class="agenda-tl__swim-head" style={`grid-column:${3 + i}`}>{l.label}</div>
	))}

	<div class="agenda-tl__gutter" aria-hidden="true">
		{ticks.map((t) => (
			<time
				class="agenda-tl__tick"
				style={`--top:${t.topPct}%`}
				datetime={t.iso}
				data-hour={t.hour}
			>
				{t.label}
			</time>
		))}
		{/* Local-midnight date, positioned by the script beside the hour labels. */}
		<span class="agenda-tl__turnover-label" hidden></span>
	</div>

	{/* Hourly gridlines, spanning the main track + every side column. */}
	<div class="agenda-tl__rules" aria-hidden="true">
		{hourLines.map((l) => (
			<div
				class="agenda-tl__line"
				data-major={l.major ? "" : undefined}
				style={`--top:${l.topPct}%`}
			/>
		))}
	</div>

	<div class="agenda-tl__track" data-day-start={dayStartMs}>
		{empty && <p class="agenda-tl__empty">{t("timeline.empty")}</p>}

		<ul class="agenda-tl__bars">
			{bars.map(({ event, startFrac, endFrac, openStart, openEnd, lane, laneCount }) => {
				const { href, external } = eventLink(event);
				const title = event.titleEn ?? event.titleJa;
				const sched = scheduleInfo(event);
				const Inner = href ? "a" : "div";
				return (
					<li
						class="agenda-tl__bar"
						data-etype={event.type}
						data-source={sched ? "schedule" : undefined}
						data-open-start={openStart ? "" : undefined}
						data-open-end={openEnd ? "" : undefined}
						style={`--top:${startFrac * 100}%; --h:${(endFrac - startFrac) * 100}%; --lane:${lane}; --lanes:${laneCount}`}
					>
						<Inner
							class="agenda-tl__bar-inner"
							href={href}
							data-linked={href ? "" : undefined}
							target={external ? "_blank" : undefined}
							rel={external ? "noopener" : undefined}
						>
							<span class="agenda-tl__bar-name">
								{sched?.iconUrl && (
									<img class="agenda-tl__icon" src={sched.iconUrl} alt="" />
								)}
								{title}
							</span>
							<span class="agenda-tl__bar-when">
								{openStart && <span class="agenda-tl__arrow" aria-hidden="true">↑ </span>}
								<time class="agenda-tl__time" datetime={event.startTime.toInstant().toString()}>
									{jstTime(event.startTime)}
								</time>
								{event.endTime && (
									<>
										<span aria-hidden="true"> – </span>
										<time class="agenda-tl__time" datetime={event.endTime.toInstant().toString()}>
											{jstTime(event.endTime)}
										</time>
									</>
								)}
								{openEnd && <span class="agenda-tl__arrow" aria-hidden="true"> ↓</span>}
							</span>
						</Inner>
					</li>
				);
			})}
		</ul>

		<ul class="agenda-tl__marks">
			{milestones.map(({ event, frac }) => {
				const { href, external } = eventLink(event);
				const title = event.titleEn ?? event.titleJa;
				const Label = href ? "a" : "span";
				return (
					<li class="agenda-tl__mark" style={`--top:${frac * 100}%`}>
						<Label
							class="agenda-tl__mark-label"
							href={href}
							data-linked={href ? "" : undefined}
							target={external ? "_blank" : undefined}
							rel={external ? "noopener" : undefined}
						>
							{title}
							<time class="agenda-tl__time" datetime={event.startTime.toInstant().toString()}>
								{jstTime(event.startTime)}
							</time>
						</Label>
					</li>
				);
			})}
		</ul>

	</div>

	{lanes.map((l, i) => (
		<ul class="agenda-tl__swim" data-lane={l.key} style={`grid-column:${3 + i}`}>
			{l.bars.map(({ event, startFrac, endFrac }) => {
				const title = event.titleEn ?? event.titleJa;
				const icon = scheduleInfo(event)?.iconUrl;
				return (
					<li
						class="agenda-tl__swim-bar"
						data-start={startFrac}
						data-end={endFrac}
						style={`--top:${startFrac * 100}%; --h:${(endFrac - startFrac) * 100}%`}
					>
						<a
							class="agenda-tl__swim-inner"
							href={TSUYOSA_URL}
							target="_blank"
							rel="noopener"
							title={`${title}（${jstTime(event.startTime)}）`}
						>
							{l.key === "metal" ? (
								<svg
									class="agenda-tl__slime"
									viewBox="0 0 321 325"
									fill="currentColor"
									aria-hidden="true"
								>
									<path d="m160.4 0c-23 0-21.5 18.5-27.5 42-6 23.5-34.5 51-77 74.5-42.5 23.5-61.5 60.5-54.5 104 7 43.5 46 105 159.5 105 113.5 0 152-61.5 159-105s-12-80.5-54.5-104-71-51-77-74.5-5-42-28-42zm-82.6 228.7c3.8-3.7 9.8-3.55 13.4336.221 27.15 28 59.6528 28.106 69.6728 28.106 9.979 0 42.011-.039 69.173-28.106 3.648-3.771 9.663-3.869 13.433-.221 3.771 3.648 3.87 9.663.221 13.433-32.837 33.933-71.806 33.894-82.827 33.894-10.981 0-50.475.054-83.3271-33.894-3.6483-3.77-3.5494-9.785.2207-13.433zm126.6064-83.673c18.502 0 33.5 14.998 33.5 33.5s-14.998 33.5-33.5 33.5c-18.501 0-33.5-14.999-33.5-33.5s14.999-33.5 33.5-33.5zm-87.5 0c18.502 0 33.5 14.998 33.5 33.5s-14.998 33.5-33.5 33.5c-18.5014 0-33.5-14.999-33.5-33.5s14.9986-33.5 33.5-33.5zm87.5 19c-8.008 0-14.5 6.492-14.5 14.5s6.492 14.5 14.5 14.5 14.5-6.492 14.5-14.5-6.492-14.5-14.5-14.5zm-87.5 0c-8.008 0-14.5 6.492-14.5 14.5s6.492 14.5 14.5 14.5 14.5-6.492 14.5-14.5-6.492-14.5-14.5-14.5z" />
								</svg>
							) : icon ? (
								<img class="agenda-tl__swim-icon" src={icon} alt={title} />
							) : (
								<span class="agenda-tl__swim-time">{jstTime(event.startTime)}</span>
							)}
						</a>
					</li>
				);
			})}
		</ul>
	))}

	{/* Time markers on top, spanning the main track + every side column. */}
	<div class="agenda-tl__markers" aria-hidden="true">
		<div class="agenda-tl__turnover" hidden></div>
		{/* Current-time line (positioned + revealed by the script when today). */}
		<div class="agenda-tl__now" hidden>
			<span class="agenda-tl__now-dot"></span>
			<span class="agenda-tl__now-label">{t("timeline.now")}</span>
		</div>
	</div>
</div>

<style>
	.agenda-tl {
		display: grid;
		grid-template-columns: 3.4rem 1fr repeat(var(--swim-count, 0), var(--swim-w, 4.6rem));
		grid-template-rows: auto 1fr;
		gap: 0;
	}
	/* All time layers live in body row 2, placed explicitly so the gridline and
	   marker overlays can span the main track + every side column. */
	.agenda-tl__gutter {
		grid-row: 2;
		grid-column: 1;
		position: relative;
	}
	.agenda-tl__rules,
	.agenda-tl__markers {
		grid-row: 2;
		grid-column: 2 / -1;
		position: relative;
	}
	.agenda-tl__rules {
		z-index: 0;
	}
	.agenda-tl__markers {
		z-index: 5;
		pointer-events: none;
	}
	.agenda-tl__track {
		grid-row: 2;
		grid-column: 2;
		z-index: 1;
		position: relative;
		height: clamp(620px, 74vh, 980px);
		border-left: 1px solid var(--rule-strong);
	}

	/* Reserved side columns for the always-on dense rotations (防衛軍・メタルーキー),
	   so a busy hourly schedule never reflows the main events. */
	.agenda-tl__swim-head {
		grid-row: 1;
		font-size: 0.62rem;
		font-weight: 700;
		letter-spacing: 0.02em;
		text-align: center;
		color: var(--ink-faint);
		padding-bottom: 0.25rem;
		align-self: end;
	}
	.agenda-tl__swim {
		grid-row: 2;
		z-index: 1;
		position: relative;
		list-style: none;
		margin: 0;
		padding: 0;
		border-left: 1px solid var(--rule);
	}
	/* The active brigade / rookie march at the current time. */
	.agenda-tl__swim-bar.is-now .agenda-tl__swim-inner {
		outline: 2px solid var(--red-9);
		outline-offset: -1px;
	}
	.agenda-tl__swim-bar {
		position: absolute;
		top: var(--top);
		height: var(--h);
		left: 2px;
		right: 2px;
		min-height: 1.1rem;
	}
	/* A filled rectangle spanning the rotation's window, with its icon inside —
	   tinted like the main schedule bars so the two read as the same family. */
	.agenda-tl__swim-inner {
		display: flex;
		align-items: center;
		justify-content: center;
		height: 100%;
		padding: 1px;
		overflow: hidden;
		box-sizing: border-box;
		background: linear-gradient(
			180deg,
			color-mix(in oklch, var(--purple-9) 22%, var(--surface-panel)),
			color-mix(in oklch, var(--purple-9) 12%, var(--surface-panel))
		);
		border: 1px solid color-mix(in oklch, var(--purple-9) 45%, var(--border));
		box-shadow: var(--inset-top), var(--shadow-sm);
		transition:
			filter 0.12s ease,
			box-shadow 0.12s ease;
	}
	/* Metal-slime rotations get a brushed-silver box with the slime crest inside. */
	.agenda-tl__swim[data-lane="metal"] .agenda-tl__swim-inner {
		background: linear-gradient(
			160deg,
			#fafbfc 0%,
			#d5d9de 40%,
			#aeb4bd 52%,
			#cbcfd5 68%,
			#eef0f3 100%
		);
		border-color: #9aa0a8;
	}
	/* Dark mode: a gunmetal silver so the ink-colored crest (now light) still reads. */
	:global(.dark) .agenda-tl__swim[data-lane="metal"] .agenda-tl__swim-inner,
	:global([data-theme="dark"]) .agenda-tl__swim[data-lane="metal"] .agenda-tl__swim-inner {
		background: linear-gradient(
			160deg,
			#828892 0%,
			#4a505a 40%,
			#31353d 52%,
			#4d535d 68%,
			#8b919b 100%
		);
		border-color: #5b616a;
	}
	@media (prefers-color-scheme: dark) {
		:global(:root:not(.light)) .agenda-tl__swim[data-lane="metal"] .agenda-tl__swim-inner {
			background: linear-gradient(
				160deg,
				#828892 0%,
				#4a505a 40%,
				#31353d 52%,
				#4d535d 68%,
				#8b919b 100%
			);
			border-color: #5b616a;
		}
	}
	a.agenda-tl__swim-inner:hover {
		filter: brightness(1.05);
		box-shadow: var(--inset-top), var(--shadow-md);
	}
	.agenda-tl__swim-icon {
		max-width: 100%;
		max-height: 100%;
		width: auto;
		height: auto;
	}
	/* Slime crest, rendered in the ink/text color against the silver box. */
	.agenda-tl__slime {
		height: 100%;
		width: 100%;
		color: var(--ink);
	}
	.agenda-tl__swim-time {
		font-size: 0.6rem;
		color: var(--ink-faint);
		font-variant-numeric: tabular-nums;
	}

	/* Brigade/boss icon shown in icon-only schedule events (no readable name). */
	.agenda-tl__icon {
		height: 1.05em;
		width: auto;
		max-width: 3.2em;
		vertical-align: -0.15em;
		margin-right: 0.3rem;
	}

	/* Hour ticks + gridlines */
	.agenda-tl__tick {
		position: absolute;
		top: var(--top);
		right: 0.5rem;
		transform: translateY(-0.5em);
		font-size: 0.72rem;
		font-variant-numeric: tabular-nums;
		color: var(--ink-faint);
		white-space: nowrap;
	}
	.agenda-tl__line {
		position: absolute;
		top: var(--top);
		left: 0;
		right: 0;
		height: 0;
		/* Every-hour lines stay faint; the 3h label boundaries read a touch stronger. */
		border-top: 1px solid
			color-mix(in oklch, var(--rule), transparent 78%);
	}
	.agenda-tl__line[data-major] {
		border-top-style: dashed;
		border-top-color: color-mix(in oklch, var(--rule), transparent 35%);
	}

	.agenda-tl__empty {
		position: absolute;
		top: 50%;
		left: 0;
		right: 0;
		transform: translateY(-50%);
		text-align: center;
		margin: 0;
		color: var(--ink-faint);
		font-style: italic;
	}

	/* Bars */
	.agenda-tl__bars,
	.agenda-tl__marks {
		list-style: none;
		margin: 0;
		padding: 0;
	}
	.agenda-tl__bar {
		position: absolute;
		top: var(--top);
		height: var(--h);
		min-height: 1.5rem;
		left: calc(var(--lane) / var(--lanes) * 100% + 0.35rem);
		width: calc(100% / var(--lanes) - 0.7rem);
		box-sizing: border-box;
	}
	.agenda-tl__bar-inner {
		display: block;
		height: 100%;
		overflow: hidden;
		padding: 0.28rem 0.45rem;
		box-sizing: border-box;
		text-decoration: none;
		color: inherit;
		background: linear-gradient(
			180deg,
			color-mix(in oklch, var(--cat, var(--gold-mid)) 26%, var(--surface-panel)),
			color-mix(in oklch, var(--cat, var(--gold-mid)) 14%, var(--surface-panel))
		);
		border: 1px solid color-mix(in oklch, var(--cat, var(--gold-mid)) 55%, var(--border));
		border-left: 3px solid var(--cat, var(--gold-mid));
		box-shadow: var(--inset-top), var(--shadow-sm);
		transition:
			filter 0.12s ease,
			box-shadow 0.12s ease;
	}
	/* Linked bars invite a click. */
	a.agenda-tl__bar-inner:hover {
		filter: brightness(1.04);
		box-shadow: var(--inset-top), var(--shadow-md);
	}
	a.agenda-tl__bar-inner:hover .agenda-tl__bar-name {
		text-decoration: underline;
	}
	/* Open edges continue past the day — flatten the crossed edge. */
	.agenda-tl__bar[data-open-start] .agenda-tl__bar-inner {
		border-top-left-radius: 0;
		border-top-right-radius: 0;
		border-top-style: dashed;
	}
	.agenda-tl__bar[data-open-end] .agenda-tl__bar-inner {
		border-bottom-left-radius: 0;
		border-bottom-right-radius: 0;
		border-bottom-style: dashed;
	}
	.agenda-tl__bar[data-etype="span"] {
		--cat: var(--blue-9);
	}
	.agenda-tl__bar[data-etype="multiDay"] {
		--cat: var(--orange-9);
	}
	/* Scraped game-schedule rotations read apart from article events. */
	.agenda-tl__bar[data-source="schedule"] {
		--cat: var(--purple-9);
	}
	.agenda-tl__bar-name {
		display: block;
		font-size: 0.82rem;
		font-weight: 650;
		line-height: 1.25;
		color: var(--ink);
	}
	.agenda-tl__bar-when {
		font-size: 0.72rem;
		color: var(--ink-soft);
		font-variant-numeric: tabular-nums;
	}
	.agenda-tl__arrow {
		font-weight: 700;
		color: var(--ink-faint);
	}

	/* Milestones — a quiet point-in-time mark (kept muted so it doesn't read as
	   the current-time line, which is the loud red one below). */
	.agenda-tl__mark {
		position: absolute;
		top: var(--top);
		left: 0;
		right: 0;
		/* Inset the label to match the bars; the line (::before) stays full width. */
		padding-left: 0.35rem;
		display: flex;
		align-items: center;
		gap: 0.4rem;
		pointer-events: none;
	}
	.agenda-tl__mark::before {
		content: "";
		position: absolute;
		left: 0;
		right: 0;
		height: 0;
		border-top: 1.5px dashed
			color-mix(in oklch, var(--ink-soft), transparent 55%);
	}
	.agenda-tl__mark-label {
		position: relative;
		pointer-events: auto;
		background: var(--surface-panel);
		border: 1px solid var(--border);
		box-shadow: var(--shadow-sm);
		padding: 0.1rem 0.4rem;
		font-size: 0.76rem;
		font-weight: 600;
		color: var(--ink);
		text-decoration: none;
		display: inline-flex;
		gap: 0.4rem;
		align-items: baseline;
	}
	a.agenda-tl__mark-label:hover {
		border-color: var(--gold-edge);
		text-decoration: underline;
	}
	.agenda-tl__mark-label time {
		color: var(--ink-faint);
		font-variant-numeric: tabular-nums;
	}

	/* Local-midnight turnover: a dotted line across the track; its date label
	   lives in the gutter beside the hour labels (script-positioned). */
	.agenda-tl__turnover {
		position: absolute;
		left: 0;
		right: 0;
		height: 0;
		border-top: 2px dotted var(--gold-edge);
		z-index: 3;
	}
	.agenda-tl__turnover-label {
		position: absolute;
		top: var(--top);
		right: 0.5rem;
		transform: translateY(-0.5em);
		font-size: 0.62rem;
		font-weight: 700;
		letter-spacing: 0.02em;
		color: var(--gold-edge);
		white-space: nowrap;
	}

	/* Current-time line — the loud red "now" indicator (only on today). */
	.agenda-tl__now {
		position: absolute;
		left: 0;
		right: 0;
		height: 0;
		border-top: 2px solid var(--red-9);
		z-index: 4;
	}
	.agenda-tl__now-dot {
		position: absolute;
		left: 0;
		top: 0;
		transform: translate(-50%, -50%);
		width: 0.6rem;
		height: 0.6rem;
		border-radius: 50%;
		background: var(--red-9);
		box-shadow: 0 0 0 3px color-mix(in oklch, var(--red-9) 22%, transparent);
	}
	.agenda-tl__now-label {
		position: absolute;
		right: 0.35rem;
		top: 0;
		transform: translateY(-50%);
		font-size: 0.6rem;
		font-weight: 800;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: var(--surface-panel);
		background: var(--red-9);
		padding: 0.05rem 0.35rem;
		border-radius: 2px;
	}
</style>

<script>
	import { localizeTimes } from "../scripts/time-pref";

	const DAY_MS = 86_400_000;
	const track = document.querySelector<HTMLElement>(".agenda-tl__track");
	const dayStartMs = Number(track?.dataset.dayStart);

	// The UI language (from <html lang>) sets the number/format locale; the zone
	// is always the viewer's own.
	const uiLocale = document.documentElement.lang || undefined;

	if (localizeTimes()) {
		const fmtTime = (dt: string) =>
			new Date(dt).toLocaleTimeString(uiLocale, { hour: "numeric", minute: "2-digit" });

		// Relabel the hour ticks and every bar/mark time to the viewer's zone.
		for (const el of document.querySelectorAll<HTMLTimeElement>(
			".agenda-tl__tick, .agenda-tl__time",
		)) {
			const dt = el.getAttribute("datetime");
			if (!dt) continue;
			const local = fmtTime(dt);
			el.textContent = el.classList.contains("agenda-tl__tick")
				? local.replace(/:00(?=\s|$)/, "") // ticks: drop the :00 minutes
				: local;
		}

		// Mark where the viewer's local midnight crosses the JST day (only one can
		// fall inside a 24h window): a dotted line across the track, dated in the
		// gutter beside the hour labels.
		const line = document.querySelector<HTMLElement>(".agenda-tl__turnover");
		const label = document.querySelector<HTMLElement>(".agenda-tl__turnover-label");
		if (line && label && Number.isFinite(dayStartMs)) {
			const midnight = new Date(dayStartMs);
			midnight.setHours(24, 0, 0, 0); // next local midnight after day start
			const frac = (midnight.getTime() - dayStartMs) / DAY_MS;
			if (frac > 0.0001 && frac < 0.9999) {
				line.style.top = `${frac * 100}%`;
				label.style.setProperty("--top", `${frac * 100}%`);
				label.textContent = midnight.toLocaleDateString(uiLocale, {
					month: "short",
					day: "numeric",
				});
				line.hidden = false;
				label.hidden = false;
			}
		}
	}

	// Current-time line — independent of the timezone preference (now is now).
	// Only lands inside the axis when the day being viewed is today; re-placed
	// every couple of minutes so it keeps up on a page left open. Also flags the
	// brigade / rookie-march bar active at this moment in the side columns.
	const now = document.querySelector<HTMLElement>(".agenda-tl__now");
	const swimBars = document.querySelectorAll<HTMLElement>(".agenda-tl__swim-bar");
	if (now && Number.isFinite(dayStartMs)) {
		const placeNow = () => {
			const frac = (Date.now() - dayStartMs) / DAY_MS;
			const onToday = frac > 0 && frac < 1;
			if (onToday) now.style.top = `${frac * 100}%`;
			now.hidden = !onToday;
			for (const bar of swimBars) {
				const start = Number(bar.dataset.start);
				const end = Number(bar.dataset.end);
				bar.classList.toggle("is-now", onToday && frac >= start && frac < end);
			}
		};
		placeNow();
		setInterval(placeNow, 120_000);
	}
</script>
