---
/**
 * Pagination — cursor-based Newest/Older pills for the list pages. "Newest"
 * appears once the reader has paged (a cursor is set); "Older" appears while
 * more pages remain.
 */
import { useTranslations } from "../i18n";

interface Props {
	/** The list page's own URL, without any cursor query. */
	baseUrl: string;
	/** The cursor the current page was requested with, if any. */
	cursor?: string;
	hasMore: boolean;
	nextCursor?: string;
}

const { baseUrl, cursor, hasMore, nextCursor } = Astro.props;
const t = useTranslations(Astro.locals.lang ?? "en");
---

<nav class="pagination" aria-label={t("pagination.aria")}>
	<span>
		{cursor && <a href={baseUrl} class="pill pill--ghost">{t("pagination.newest")}</a>}
	</span>
	<span>
		{hasMore && nextCursor && (
			<a href={`${baseUrl}?cursor=${encodeURIComponent(nextCursor)}`} class="pill">{t("pagination.older")}</a>
		)}
	</span>
</nav>
