---
/**
 * Home-page rotation banner carousel. Renders the localized banner images
 * (translated text baked in) as an auto-advancing slideshow with prev/next
 * controls and dots. Auto-advance pauses on hover/focus and is disabled under
 * prefers-reduced-motion. Server-rendered markup; the small script only wires
 * interactivity, so the first banner is visible without JS.
 */
import type { CarouselBanner } from "../lib/banners";
import { useTranslations } from "../i18n";

interface Props {
  banners: CarouselBanner[];
}

const { banners } = Astro.props;
const multiple = banners.length > 1;
const t = useTranslations(Astro.locals.lang ?? "en");
---

{
  banners.length > 0 && (
    <section
      class="banners"
      aria-roledescription="carousel"
      aria-label={t("banner.aria")}
    >
      <div class="banners__frame">
        <div class="banners__viewport">
          <ul class="banners__track" role="list">
            {banners.map((b, i) => (
              <li
                class="banners__slide"
                role="group"
                aria-roledescription="slide"
                aria-label={t("banner.slide", { n: i + 1, total: banners.length })}
              >
                <a
                  class="banners__link"
                  href={b.href}
                  {...(b.external
                    ? { target: "_blank", rel: "noopener noreferrer" }
                    : {})}
                >
                  <picture>
                    {(b.sources ?? []).map((s) => (
                      <source type={s.type} srcset={s.src} />
                    ))}
                    <img
                      src={b.imageUrl}
                      alt={b.alt}
                      width={b.width ?? 632}
                      height={b.height ?? 157}
                      loading={i === 0 ? "eager" : "lazy"}
                      decoding="async"
                    />
                  </picture>
                </a>
              </li>
            ))}
          </ul>
        </div>

        {multiple && (
          <>
            <button
              class="banners__nav banners__nav--prev"
              type="button"
              aria-label={t("banner.prev")}
            >
              ‹
            </button>
            <button
              class="banners__nav banners__nav--next"
              type="button"
              aria-label={t("banner.next")}
            >
              ›
            </button>
          </>
        )}
      </div>

      {multiple && (
        <div class="banners__dots" role="tablist" aria-label={t("banner.choose")}>
          {banners.map((_, i) => (
            <button
              class="banners__dot"
              type="button"
              role="tab"
              aria-label={t("banner.dot", { n: i + 1 })}
              aria-selected={i === 0 ? "true" : "false"}
              data-dot={i}
            />
          ))}
        </div>
      )}
    </section>
  )
}

<style>
  .banners {
    max-width: var(--page-max, 860px);
    margin: 0 auto 1.8rem;
  }

  /* Gilded matte frame around the banner — the quest-scroll treatment the rest
     of the site uses (gold edge + inset gilt line + corner brackets). */
  .banners__frame {
    position: relative;
    padding: 7px;
    background: linear-gradient(
      180deg,
      color-mix(in oklch, var(--surface-panel), var(--gold) 5%),
      color-mix(in oklch, var(--surface-sunken), var(--gold) 9%)
    );
    border: 1px solid var(--gold-edge);
    box-shadow:
      var(--shadow-md),
      var(--inset-top),
      inset 0 0 0 3px color-mix(in oklch, var(--gold) 42%, var(--surface-panel));
  }
  /* Corner brackets, echoing .framed. */
  .banners__frame::before,
  .banners__frame::after {
    content: "";
    position: absolute;
    width: 11px;
    height: 11px;
    border: 2px solid var(--gold);
    pointer-events: none;
    z-index: 2;
  }
  .banners__frame::before {
    top: 4px;
    left: 4px;
    border-right: none;
    border-bottom: none;
  }
  .banners__frame::after {
    bottom: 4px;
    right: 4px;
    border-left: none;
    border-top: none;
  }

  .banners__viewport {
    overflow: hidden;
    border: 1px solid color-mix(in oklch, var(--gold-edge) 45%, var(--border));
    box-shadow: inset 0 1px 3px oklch(0% 0 0 / 0.18);
  }
  .banners__track {
    display: flex;
    list-style: none;
    margin: 0;
    padding: 0;
    transition: transform 0.5s ease;
  }
  .banners__slide {
    flex: 0 0 100%;
    min-width: 0;
  }
  .banners__link {
    display: block;
  }
  .banners__link img {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 632 / 157;
    object-fit: cover;
  }

  /* Sharp gilt nav buttons, matching the settings control. */
  .banners__nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 2rem;
    height: 2rem;
    display: grid;
    place-items: center;
    font-size: 1.35rem;
    line-height: 1;
    color: var(--gold-ink);
    background: linear-gradient(180deg, var(--surface-panel), var(--surface-panel-2));
    border: 1px solid var(--gold-edge);
    cursor: pointer;
    box-shadow: var(--inset-top), var(--shadow-sm);
    transition:
      background 0.15s ease,
      color 0.15s ease,
      border-color 0.15s ease;
  }
  .banners__nav:hover {
    background: linear-gradient(180deg, var(--gold), var(--gold-mid));
    color: var(--band-ink);
    border-color: var(--gold-edge);
  }
  .banners__nav--prev {
    left: 0.65rem;
  }
  .banners__nav--next {
    right: 0.65rem;
  }

  /* Gold-diamond position markers, echoing the ornament gem. */
  .banners__dots {
    display: flex;
    justify-content: center;
    gap: 0.55rem;
    margin-top: 0.85rem;
  }
  .banners__dot {
    width: 0.5rem;
    height: 0.5rem;
    padding: 0;
    transform: rotate(45deg);
    background: transparent;
    border: 1px solid var(--gold-edge);
    cursor: pointer;
    transition:
      background 0.15s ease,
      box-shadow 0.15s ease;
  }
  .banners__dot:hover {
    background: color-mix(in oklch, var(--gold) 40%, transparent);
  }
  .banners__dot[aria-selected="true"] {
    background: var(--gold);
    box-shadow: var(--inset-top);
  }

  @media (max-width: 600px) {
    .banners__nav {
      width: 1.8rem;
      height: 1.8rem;
      font-size: 1.2rem;
    }
  }
</style>

<script>
  const root = document.querySelector<HTMLElement>(".banners");
  const track = root?.querySelector<HTMLElement>(".banners__track");
  if (root && track) {
    const slides = root.querySelectorAll(".banners__slide");
    const dots = root.querySelectorAll<HTMLElement>(".banners__dot");
    const count = slides.length;
    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    let index = 0;
    let timer: ReturnType<typeof setInterval> | undefined;

    const go = (i: number) => {
      index = (i + count) % count;
      track.style.transform = `translateX(-${index * 100}%)`;
      dots.forEach((d, di) =>
        d.setAttribute("aria-selected", di === index ? "true" : "false"),
      );
    };
    const stop = () => {
      if (timer) clearInterval(timer);
      timer = undefined;
    };
    const start = () => {
      stop();
      if (!reduce && count > 1) timer = setInterval(() => go(index + 1), 6000);
    };

    root
      .querySelector(".banners__nav--next")
      ?.addEventListener("click", () => (go(index + 1), start()));
    root
      .querySelector(".banners__nav--prev")
      ?.addEventListener("click", () => (go(index - 1), start()));
    dots.forEach((d, di) =>
      d.addEventListener("click", () => (go(di), start())),
    );
    root.addEventListener("mouseenter", stop);
    root.addEventListener("mouseleave", start);
    root.addEventListener("focusin", stop);
    root.addEventListener("focusout", start);

    start();
  }
</script>
