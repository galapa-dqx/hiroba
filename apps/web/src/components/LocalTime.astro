---
/**
 * LocalTime — a <time> element for an instant, rewritten into the viewer's
 * local timezone on the client. The server renders the JST value as a no-JS
 * baseline (the source publishes in JST); the colocated inline script runs
 * during parse, so there's no flash of the unlocalized value.
 */

import { dateLocale } from "../i18n";

interface Props {
	/** The instant, as epoch milliseconds (Temporal.Instant.epochMilliseconds). */
	epochMs: number;
	/** 'date' renders a calendar date; 'datetime' adds the time of day. */
	mode?: "date" | "datetime";
}

const { epochMs, mode = "datetime" } = Astro.props;

// The active UI language sets the date format locale (see i18n/dateLocale).
const locale = dateLocale(Astro.locals.lang ?? "en");

const options: Intl.DateTimeFormatOptions = {
	year: "numeric",
	month: "long",
	day: "numeric",
	...(mode === "datetime" ? { hour: "numeric", minute: "2-digit" } : {}),
};
const baseline = new Date(epochMs).toLocaleString(locale, {
	...options,
	timeZone: "Asia/Tokyo",
});
---

<time datetime={new Date(epochMs).toISOString()}
	>{baseline}<script define:vars={{ epochMs, mode, locale }}>
		const el = document.currentScript.parentElement;
		el.textContent = new Date(epochMs).toLocaleString(locale, {
			year: "numeric",
			month: "long",
			day: "numeric",
			...(mode === "datetime" ? { hour: "numeric", minute: "2-digit" } : {}),
		});
	</script></time
>
