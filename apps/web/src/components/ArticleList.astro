---
/**
 * ArticleList — the parchment ledger of article rows (news items, topics, or
 * playguides), each row a localized title (falling back to Japanese) with its
 * publication date when it has one. Playguides are undated reference pages, so
 * `publishedAt` is optional and the date is simply omitted for them. The "empty"
 * slot customizes the no-items message.
 */
import { formatShortDate } from "@hiroba/ui";
import { dateLocale, useTranslations } from "../i18n";

interface Props {
	items: Array<{
		id: string;
		titleJa: string;
		localizedTitle: string | null;
		publishedAt?: { epochMilliseconds: number } | null;
	}>;
	/** Detail-page prefix the row links under: "/news", "/topics", "/playguide". */
	hrefBase: string;
}

const { items, hrefBase } = Astro.props;
const lang = Astro.locals.lang ?? "en";
const t = useTranslations(lang);
const locale = dateLocale(lang);
---

{
	items.length > 0 ? (
		<ul class="news-list">
			{items.map((item) => (
				<li>
					<a href={`${hrefBase}/${item.id}`}>
						<span class="news-list__title">{item.localizedTitle ?? item.titleJa}</span>
						{item.publishedAt && (
							<time datetime={new Date(item.publishedAt.epochMilliseconds).toISOString()}>
								{formatShortDate(item.publishedAt.epochMilliseconds, locale)}
							</time>
						)}
					</a>
				</li>
			))}
		</ul>
	) : (
		<slot name="empty">
			<p class="empty">{t("list.empty")}</p>
		</slot>
	)
}
