---
/**
 * CategoryDot — the category gem beside a `.chip` (shares the admin category-badge
 * treatment). Each category gets a distinct cut (news = round · event = pentagon ·
 * update = tall emerald · maintenance = marquise). It's an inline SVG so `fill` and
 * `stroke` can use `currentColor` — `.cat-dot` sets `color: var(--cat)`, so the dot
 * stays theme-adaptive with no baked-in colours. `paint-order: stroke` puts the
 * translucent stroke under the fill for a uniform external outline that hugs the cut.
 */
interface Props {
  category: string;
  class?: string;
}
const { category, class: className } = Astro.props;

const PATHS: Record<string, string> = {
  event: "M16 5 L26.46 12.6 L22.47 24.9 L9.53 24.9 L5.54 12.6 Z",
  update: "M14 5 L18 5 L21 8 L21 24 L18 27 L14 27 L11 24 L11 8 Z",
  maintenance: "M16 5 Q27 16 16 27 Q5 16 16 5 Z",
};
---

<svg class:list={["cat-dot", className]} viewBox="0 0 32 32" aria-hidden="true">
  {
    category === "news" ? (
      <circle
        cx="16"
        cy="16"
        r="11"
        fill="currentColor"
        stroke="currentColor"
        stroke-opacity="0.4"
        stroke-width="8.4"
        paint-order="stroke"
      />
    ) : (
      <path
        d={PATHS[category] ?? PATHS.event}
        fill="currentColor"
        stroke="currentColor"
        stroke-opacity="0.4"
        stroke-width="8.4"
        stroke-linejoin="round"
        paint-order="stroke"
      />
    )
  }
</svg>
