---
import Layout from "../layouts/Layout.astro";
import ArticleList from "../components/ArticleList.astro";
import PanelSection from "../components/PanelSection.astro";
import Ornament from "@hiroba/ui/Ornament.astro";
import { createDb, getNewsItems } from "@hiroba/db";
import { CATEGORIES, CATEGORY_LABELS } from "@hiroba/shared";

const runtime = Astro.locals.runtime;
const db = createDb(runtime.env.DB);

const newsByCategory = await Promise.all(
	CATEGORIES.map(async (category) => {
		try {
			const { items } = await getNewsItems(db, { category, limit: 5 });
			return { category, items };
		} catch {
			return { category, items: [] };
		}
	})
);

---

<Layout title="Latest News">
	<section class="home-hero">
		<h1>DQX&nbsp;News</h1>
		<p class="subtitle">Dispatches from Astoltia — Dragon Quest&nbsp;X news, translated to English.</p>
		<Ornament class="home-hero__rule" />
	</section>

	<div class="stack">
		{
			newsByCategory.map(({ category, items }) => (
				<PanelSection
					title={CATEGORY_LABELS[category]}
					titleHref={`/category/${category}`}
					moreHref={`/category/${category}`}
					category={category}
				>
					<ArticleList items={items} hrefBase="/news" />
				</PanelSection>
			))
		}
	</div>
</Layout>

<style>
	.home-hero {
		text-align: center;
		margin-bottom: 1.8rem;
	}
	.home-hero h1 {
		font-size: clamp(2rem, 1.4rem + 3vw, 3rem);
	}
	.home-hero .subtitle {
		max-width: 46ch;
		margin-inline: auto;
	}
	.home-hero__rule {
		margin-top: 1.3rem;
	}
</style>
