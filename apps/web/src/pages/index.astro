---
import Layout from "../layouts/Layout.astro";
import Gem from "../components/Gem.astro";
import Ornament from "@hiroba/ui/Ornament.astro";
import { formatShortDate } from "@hiroba/ui";
import { createDb, getNewsItems } from "@hiroba/db";
import { CATEGORIES, CATEGORY_LABELS, type Category } from "@hiroba/shared";

const runtime = Astro.locals.runtime;
const db = createDb(runtime.env.DB);

const newsByCategory = await Promise.all(
	CATEGORIES.map(async (category) => {
		try {
			const { items } = await getNewsItems(db, { category, limit: 5 });
			return { category, items };
		} catch {
			return { category, items: [] };
		}
	})
);

---

<Layout title="Latest News">
	<section class="home-hero">
		<h1>DQX&nbsp;News</h1>
		<p class="subtitle">Dispatches from Astoltia — Dragon Quest&nbsp;X news, translated to English.</p>
		<Ornament class="home-hero__rule" />
	</section>

	<div class="stack">
		{
			newsByCategory.map(({ category, items }) => (
				<section class="panel" data-cat={category}>
					<div class="band-heading">
						<Gem category={category} />
						<span class="band-heading__title">
							<a href={`/category/${category}`}>{CATEGORY_LABELS[category as Category]}</a>
						</span>
						<a class="band-heading__more" href={`/category/${category}`}>
							View all <span class="band-heading__chevrons" aria-hidden="true">››</span>
						</a>
					</div>
					<div class="panel__body">
						{items.length > 0 ? (
							<ul class="news-list">
								{items.map((item) => (
									<li>
										<a href={`/news/${item.id}`}>
											<span class="news-list__title">{item.titleEn ?? item.titleJa}</span>
											<time datetime={item.publishedAt.toString()}>
												{formatShortDate(item.publishedAt.epochMilliseconds)}
											</time>
										</a>
									</li>
								))}
							</ul>
						) : (
							<p class="empty">No dispatches have arrived yet.</p>
						)}
					</div>
				</section>
			))
		}
	</div>
</Layout>

<style>
	.home-hero {
		text-align: center;
		margin-bottom: 1.8rem;
	}
	.home-hero h1 {
		font-size: clamp(2rem, 1.4rem + 3vw, 3rem);
	}
	.home-hero .subtitle {
		max-width: 46ch;
		margin-inline: auto;
	}
	.home-hero__rule {
		margin-top: 1.3rem;
	}
	.band-heading__more {
		flex: none;
	}
</style>
