---
import Layout from "../../layouts/Layout.astro";
import { createDb, getTopics, type Topic } from "@hiroba/db";
import { formatShortDate } from "@hiroba/ui";

const cursor = Astro.url.searchParams.get("cursor") ?? undefined;

const runtime = Astro.locals.runtime;
const db = createDb(runtime.env.DB);

let items: Topic[] = [];
let hasMore = false;
let nextCursor: string | undefined;

try {
	const result = await getTopics(db, { limit: 20, cursor });
	items = result.items;
	hasMore = result.hasMore;
	nextCursor = result.nextCursor;
} catch {
	// Show empty list on error
}

---

<Layout title="Topics">
	{/* Gilt identity, distinct from the four news categories. */}
	<div
		class="topics"
		style="--cat: var(--gold-mid); --cat-ink: var(--gold-ink);"
	>
		<section class="panel">
			<div class="band-heading">
				<span class="band-heading__title">Topics</span>
				<span class="band-heading__chevrons" aria-hidden="true">››</span>
			</div>
			<div class="panel__body">
				{
					items.length > 0 ? (
						<ul class="news-list">
							{items.map((t) => (
								<li>
									<a href={`/topics/${t.id}`}>
										<span class="news-list__title">{t.titleJa}</span>
										<time datetime={t.publishedAt.toString()}>
											{formatShortDate(t.publishedAt.epochMilliseconds)}
										</time>
									</a>
								</li>
							))}
						</ul>
					) : (
						<p class="empty">
							No topics yet. Open a topic URL like <code>/topics/&lt;id&gt;</code> to fetch,
							transcribe and translate it — or seed them from the admin.
						</p>
					)
				}
			</div>
		</section>

		<nav class="pagination" aria-label="Pagination">
			<span>
				{cursor && <a href="/topics" class="pill pill--ghost">‹ Newest</a>}
			</span>
			<span>
				{hasMore && nextCursor && (
					<a href={`/topics?cursor=${encodeURIComponent(nextCursor)}`} class="pill">Older ›</a>
				)}
			</span>
		</nav>

		<nav class="back-link">
			<a href="/" class="pill pill--ghost">‹ Back to home</a>
		</nav>
	</div>
</Layout>
