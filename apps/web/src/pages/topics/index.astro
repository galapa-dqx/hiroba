---
import Layout from "../../layouts/Layout.astro";
import { createDb, getTopics } from "@hiroba/db";

const runtime = Astro.locals.runtime;
const db = createDb(runtime.env.DB);

const cursor = Astro.url.searchParams.get("cursor") ?? undefined;
const { items, hasMore, nextCursor } = await getTopics(db, { cursor, limit: 30 });
---

<Layout title="Topics">
	<h1>Topics</h1>

	{items.length === 0 && (
		<p class="empty">
			No topics yet. Open a topic URL like <code>/topics/&lt;id&gt;</code> to fetch, transcribe and translate it.
		</p>
	)}

	<ul class="topic-list">
		{items.map((t) => (
			<li>
				<a href={`/topics/${t.id}`}>{t.titleJa}</a>
				<time class="ts" datetime={t.publishedAt.toString()} data-ms={t.publishedAt.epochMilliseconds} />
			</li>
		))}
	</ul>

	{hasMore && nextCursor && (
		<a class="more" href={`/topics?cursor=${encodeURIComponent(nextCursor)}`}>Older topics →</a>
	)}
</Layout>

<style>
	h1 { margin-bottom: 1.5rem; }
	.empty { color: var(--color-muted); }
	.topic-list { list-style: none; padding: 0; margin: 0; }
	.topic-list li { display: flex; justify-content: space-between; align-items: baseline; gap: 1rem; padding: 0.75rem 0; border-bottom: 1px solid #eee; }
	.topic-list a { text-decoration: none; color: var(--color-text); font-weight: 500; }
	.topic-list a:hover { color: var(--color-link); }
	.topic-list time { color: var(--color-muted); font-size: 0.85rem; white-space: nowrap; }
	.more { display: inline-block; margin-top: 1.5rem; color: var(--color-link); }
</style>

<script>
	for (const el of document.querySelectorAll("time.ts")) {
		const ms = Number((el as HTMLElement).dataset.ms);
		if (ms) el.textContent = new Date(ms).toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" });
	}
</script>
