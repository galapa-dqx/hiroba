---
import Layout from "../../layouts/Layout.astro";
import Rosette from "@hiroba/ui/Rosette.astro";
import Ornament from "@hiroba/ui/Ornament.astro";
import EventsRail from "../../components/EventsRail.astro";
import { computeSnapshot, createDb, getEventsForSource, getImagesByKeys, getImageTranslations, getTopic, getTopicTranslations } from "@hiroba/db";
import { collectImages, imageKey, renderBlocks, rewriteImageSrc, type Block } from "@hiroba/richtext";
import { describeSnapshot, isSnapshotComplete, isSnapshotSettled } from "@hiroba/shared";

const { id } = Astro.params;
if (!id) {
	return Astro.redirect("/topics");
}

const runtime = Astro.locals.runtime;
const db = createDb(runtime.env.DB);

const topic = await getTopic(db, id);
const { title: enTitle, blocks: enBlocks } = await getTopicTranslations(db, id, "en");

const isTranslated = !!enBlocks;

// The article displays only once its pipeline has settled — fetched, translated,
// and every text-bearing image localized (or given up on). Until then the page
// shows the processing notice and the SSE stream drives progress + reload.
const snapshot = await computeSnapshot(db, "topic", id, "en");
const ready = isSnapshotSettled(snapshot);

// Fire the topics pipeline unless everything already finished cleanly — a
// degraded-but-settled article displays now and retries its failures in the
// background. (fetch-body creates the row, so a never-seen id is valid — no 404.)
if (!isSnapshotComplete(snapshot)) {
	try {
		const doId = runtime.env.WORKFLOW_MANAGER.idFromName(`topic:${id}`);
		const stub = runtime.env.WORKFLOW_MANAGER.get(doId);
		stub.fetch("http://internal/trigger", {
			method: "POST",
			body: JSON.stringify({ itemId: id, itemType: "topic" }),
			headers: { "Content-Type": "application/json" },
		});
	} catch (error) {
		console.error(`Topics workflow trigger failed for ${id}:`, error);
	}
}

const title = enTitle ?? topic?.titleJa ?? "Loading topic…";
const blocks: Block[] = enBlocks ?? (topic?.blocksJa as Block[] | null) ?? [];

// Hydrate each image's transient `text` with the displayed language's spans, so
// renderBlocks can put it on the image as alt (image text lives in the images /
// translations tables, not the block tree). EN prefers the translated spans and
// falls back to the JA transcription.
const imgs = collectImages(blocks);
const imgKeys = [...new Set(imgs.map((i) => imageKey(i.src)).filter((k): k is string => !!k))];
// Keys whose localized (l10n/en) image actually exists. Only these get the l10n
// base below — an image that wasn't localized (no Japanese, or not done yet)
// keeps its original URL, so a browser never caches the original under an l10n
// URL and then keeps serving it after the localized version lands.
const localizedKeys = new Set<string>();
if (imgKeys.length > 0) {
	const rows = await getImagesByKeys(db, imgKeys);
	const byKey = new Map(rows.map((r) => [r.key, r]));
	const ids = rows.map((r) => r.id);
	const enText = isTranslated
		? await getImageTranslations(db, ids, "en", "text")
		: new Map<number, string>();
	const enUrl = isTranslated
		? await getImageTranslations(db, ids, "en", "url")
		: new Map<number, string>();
	for (const row of rows) if (enUrl.has(row.id)) localizedKeys.add(row.key);
	for (const img of imgs) {
		const key = imageKey(img.src);
		const row = key ? byKey.get(key) : undefined;
		const en = row && isTranslated ? enText.get(row.id) : undefined;
		const spans = en ? (JSON.parse(en) as string[]) : (row?.textsJa ?? undefined);
		if (spans && spans.length) img.text = spans;
		else delete img.text;
	}
}

// Serve English-localized images from the l10n/en/<key> object, but only for the
// images we actually localized; everything else (icons, text-free art, images
// not yet localized) keeps the original URL. Originals may come from a bucket
// custom-domain via IMAGE_BASE. The /img route still falls back to the original
// for a stray l10n request, but we no longer emit one for an unlocalized image.
const originalBase = runtime.env.IMAGE_BASE ?? "/img";
const imageSrc = (src: string): string => {
	const key = imageKey(src);
	const base = isTranslated && key && localizedKeys.has(key) ? "/img/l10n/en" : originalBase;
	return rewriteImageSrc(src, base);
};
const contentHtml = renderBlocks(blocks, { imageSrc });

// Events extracted from this topic (only meaningful once the body is shown).
const events = ready ? await getEventsForSource(db, "topic", id, "en") : [];
---

<Layout title={title}>
	{/* Topics have no category — give them a distinct gilt identity via --cat*. */}
	<article
		class="topic"
		style="--cat: var(--gold-mid); --cat-ink: var(--gold-ink); --cat-soft: var(--yellow-3); --cat-line: var(--gold-edge);"
	>
		<header class="article-header">
			<div class="meta">
				<span class="chip">Topic</span>
				{topic && (
					<time datetime={topic.publishedAt.toString()}>
						<script define:vars={{ publishedAt: topic.publishedAt.epochMilliseconds }}>
							const timeEl = document.currentScript.parentElement;
							timeEl.textContent = new Date(publishedAt).toLocaleDateString("en-US", {
								year: "numeric",
								month: "long",
								day: "numeric",
							});
						</script>
					</time>
				)}
			</div>
			<h1 class="article-title">{title}</h1>
		</header>

		{!ready && (
			<div class="callout callout--busy" id="processing-notice" data-item-id={id} role="status">
				<Rosette class="callout__glyph" />
				<p id="processing-status">{describeSnapshot(snapshot)}</p>
			</div>
		)}

		{ready && contentHtml && (
			<div class="article-grid">
				<div class="scroll">
					<div class="scroll__content topic-body" set:html={contentHtml} />
				</div>
				<EventsRail events={events} />
			</div>
		)}

		<footer class="translation-info">
			<Ornament />
			<a
				class="pill pill--ghost"
				href={`https://hiroba.dqx.jp/sc/topics/detail/${id}/`}
				target="_blank"
				rel="noopener noreferrer">View original topic ↗</a
			>
		</footer>

		<nav class="back-link">
			<a href="/topics" class="pill pill--ghost">‹ Back to topics</a>
		</nav>
	</article>
</Layout>

<style>
	.article-header {
		margin-bottom: 1.4rem;
	}
	.article-title {
		font-size: clamp(1.7rem, 1.25rem + 2.4vw, 2.5rem);
		line-height: 1.22;
	}
	.callout {
		margin-bottom: 1.5rem;
	}
	/* article body with the events panel stacked full-width beneath it */
	.article-grid {
		display: grid;
		gap: 1.5rem;
	}
	.translation-info {
		margin-top: 2.4rem;
		text-align: center;
		color: var(--ink-faint);
		font-size: 0.9rem;
	}
</style>

{/* The rendered block tree is injected via set:html, so its rt-* styles must be
    global. They map the richtext block classes onto the manuscript palette. */}
<style is:global>
	/* Structured HTML (not preformatted like the news body) — collapse whitespace. */
	.topic-body {
		white-space: normal;
	}
	.topic-body > * + * {
		margin-top: 1rem;
	}
	.topic-body img {
		max-width: 100%;
		height: auto;
	}

	/* captioned image → centered figure with a manuscript caption beneath */
	.topic-body .rt-figure {
		margin: 1.25rem auto;
		text-align: center;
	}
	.topic-body .rt-caption {
		display: block;
		max-width: 46ch;
		margin: 0.55rem auto 0;
		font-size: 0.9em;
		line-height: 1.5;
		color: var(--ink-faint);
		text-wrap: balance;
	}

	/* info box → inset parchment card (source brownroundBox; also the mini fallback) */
	.topic-body .rt-infobox {
		background: var(--surface-panel-2);
		border: 1px solid var(--border);
		border-radius: var(--radius);
		box-shadow: var(--inset-top);
		padding: 1rem 1.15rem;
	}
	/* screenshot box → just the framed image, no card (source box_ss) */
	.topic-body .rt-infobox[data-variant="screenshot"] {
		background: none;
		border: none;
		box-shadow: none;
		padding: 0;
		text-align: center;
	}
	/* quest box → a parchment scroll: gilt keyline + rolled spindles on each
	   side (the ::before/::after rollers are what set it apart from box_terms) */
	.topic-body .rt-infobox[data-variant="quest"] {
		position: relative;
		padding: 1.1rem 1.95rem;
		background: linear-gradient(
			180deg,
			color-mix(in oklch, var(--surface-panel), var(--gold) 6%),
			color-mix(in oklch, var(--surface-sunken), var(--gold) 10%)
		);
		/* no side border — the rollers are the left/right edges */
		border: 1px solid var(--gold-edge);
		border-inline: 0;
		box-shadow:
			var(--shadow-sm),
			inset 0 0 0 2px color-mix(in oklch, var(--gold) 26%, transparent);
	}
	.topic-body .rt-infobox[data-variant="quest"]::before,
	.topic-body .rt-infobox[data-variant="quest"]::after {
		content: "";
		position: absolute;
		top: -0.5rem;
		bottom: -0.5rem;
		width: 1.35rem;
		border: 1px solid var(--gold-edge);
		/* flattened horizontal-oval caps (elliptical radius), not round ends */
		border-radius: 50% / 0.35rem;
		/* soft, matte parchment shading — not a shiny metal tube */
		background: linear-gradient(
			90deg,
			oklch(74% 0.03 78),
			oklch(90% 0.025 82) 50%,
			oklch(72% 0.03 76)
		);
		box-shadow: 0 1px 2px oklch(30% 0.03 70 / 0.25);
	}
	/* flush to the edges so no parchment peeks out past the rollers */
	.topic-body .rt-infobox[data-variant="quest"]::before {
		left: 0;
	}
	.topic-body .rt-infobox[data-variant="quest"]::after {
		right: 0;
	}
	/* statistics box → a clean panel with a gilt top rule (source box01) */
	.topic-body .rt-infobox[data-variant="statistics"] {
		background: var(--surface-panel);
		border-top: 2px solid var(--gold-mid);
	}
	/* cork board → tan noise texture with pinned-board depth (source box_cork) */
	.topic-body .rt-infobox[data-variant="cork"] {
		color: oklch(24% 0.03 55);
		background-color: oklch(71% 0.05 66);
		background-image: url("data:image/svg+xml,%3Csvg%20xmlns='http://www.w3.org/2000/svg'%20width='120'%20height='120'%3E%3Cfilter%20id='n'%3E%3CfeTurbulence%20type='fractalNoise'%20baseFrequency='0.9'%20numOctaves='3'%20stitchTiles='stitch'/%3E%3CfeColorMatrix%20values='0%200%200%200%200.42%200%200%200%200%200.28%200%200%200%200%200.13%200%200%200%200.55%200'/%3E%3C/filter%3E%3Crect%20width='120'%20height='120'%20filter='url(%23n)'/%3E%3C/svg%3E");
		border: 1px solid oklch(50% 0.05 58);
		box-shadow:
			var(--inset-top),
			inset 0 0 14px oklch(38% 0.05 52 / 0.45);
	}

	/* the source's box_terms box — a gilt frame shared by the TOC nav and the
	   plain terms/spec boxes (they're the same decorative box in the source) */
	.topic-body .rt-toc,
	.topic-body .rt-infobox[data-variant="terms"] {
		margin: 1.5rem auto;
		padding: 0.95rem 1.25rem 1.05rem;
		background: linear-gradient(
			180deg,
			color-mix(in oklch, var(--surface-panel), var(--gold) 4%),
			color-mix(in oklch, var(--surface-sunken), var(--gold) 8%)
		);
		border: 1px solid var(--gold-edge);
		box-shadow:
			var(--inset-top),
			var(--shadow-sm),
			inset 0 0 0 3px color-mix(in oklch, var(--gold) 20%, transparent);
	}
	.topic-body .rt-toc > p:first-child {
		margin: 0 0 0.65rem;
		text-align: center;
		font-family: var(--font-display);
		font-size: 1.15rem;
		font-weight: 700;
		color: var(--ink);
	}
	.topic-body .rt-toc ul {
		list-style: none;
		margin: 0;
		padding: 0;
	}
	.topic-body .rt-toc li {
		display: flex;
		align-items: baseline;
		gap: 0.5rem;
		padding: 0.2rem 0;
	}
	.topic-body .rt-toc li::before {
		content: "";
		flex: none;
		align-self: center;
		width: 0.6em;
		height: 0.6em;
		background: linear-gradient(150deg, var(--gold-hi), var(--gold) 50%, var(--gold-edge));
		clip-path: polygon(50% 0, 100% 38%, 82% 100%, 18% 100%, 0 38%);
		filter: drop-shadow(0 1px 0.5px oklch(0% 0 0 / 0.3));
	}
	.topic-body .rt-toc a {
		font-weight: 600;
	}

	/* table → ruled ledger */
	.topic-body .rt-table {
		border-collapse: collapse;
		width: 100%;
		font-size: 0.94em;
	}
	.topic-body .rt-table td,
	.topic-body .rt-table th {
		border: 1px solid var(--rule);
		padding: 0.45rem 0.65rem;
		text-align: left;
	}
	.topic-body .rt-table th {
		background: var(--surface-sunken);
		font-weight: 650;
	}

	/* headerless single-column table → a clean borderless stack (layout, not data:
	   e.g. the box_terms table of contents), so it reads as a list, not a ledger */
	.topic-body .rt-table[data-variant="layout"],
	.topic-body .rt-table[data-variant="layout"] tbody,
	.topic-body .rt-table[data-variant="layout"] tr,
	.topic-body .rt-table[data-variant="layout"] td {
		display: block;
		width: auto;
		font-size: 1rem;
	}
	.topic-body .rt-table[data-variant="layout"] td {
		border: none;
		padding: 0.1rem 0;
	}
	/* tighten the airy standalone-heading spacing when items are stacked in a TOC */
	.topic-body .rt-table[data-variant="layout"] :is(.rt-h-icon, h4) {
		margin-top: 0.4rem;
	}

	/* button → gilt CTA (echoes .pill) */
	.topic-body .rt-button {
		display: inline-block;
		padding: 0.45rem 1rem;
		font-weight: 650;
		color: oklch(28% 0.05 70);
		text-decoration: none;
		border: 1px solid var(--gold-edge);
		border-radius: var(--radius);
		background: linear-gradient(180deg, var(--gold-hi), var(--gold-mid) 55%, var(--gold-edge));
		box-shadow: var(--inset-top), var(--shadow-sm);
	}

	/* badge → red chip */
	.topic-body .rt-badge {
		display: inline-block;
		margin-left: 0.3em;
		padding: 0.08em 0.45em;
		font-size: 0.72em;
		font-weight: 800;
		letter-spacing: 0.04em;
		color: oklch(99% 0.01 30);
		background: linear-gradient(180deg, var(--red-9), var(--red-10));
		border-radius: var(--radius);
	}
	/* the "Check" mark (TOC entries) → a gilt chip, not the red "New" flag */
	.topic-body .rt-badge[data-variant="checkmark"] {
		color: oklch(30% 0.05 70);
		background: linear-gradient(180deg, var(--gold-hi), var(--gold-mid));
	}

	.topic-body .rt-icon {
		display: inline;
		height: 1em;
		vertical-align: -0.12em;
	}

	.topic-body .rt-video iframe {
		width: 100%;
		aspect-ratio: 16 / 9;
		border: 0;
	}

	.topic-body .rt-interview .rt-q {
		font-weight: 650;
		color: var(--ink);
		margin-top: 1rem;
	}
	.topic-body .rt-speech,
	.topic-body .rt-message {
		padding: 0.6rem 0.9rem;
		background: var(--surface-panel-2);
		border-left: 3px solid var(--gold-edge);
	}

	/* workflow-inserted event annotation → subtle gilt marker; the data-event-*
	   attrs are the hook for future calendar linking */
	.topic-body .rt-event {
		border-bottom: 1px dashed var(--gold-edge);
	}
	/* localized timestamps carry the original JST value in the title tooltip */
	.topic-body time.rt-time[title] {
		cursor: help;
		text-decoration: underline dotted var(--gold-edge);
		text-underline-offset: 0.15em;
	}
</style>

<script>
	import { describeSnapshot } from "@hiroba/shared";
	import "../../scripts/localize-times";

	const notice = document.getElementById("processing-notice");
	if (notice) {
		const itemId = notice.dataset.itemId;
		const statusEl = document.getElementById("processing-status");
		const evtSource = new EventSource(`/api/topics/${itemId}/sse`);

		evtSource.onmessage = (event) => {
			const data = JSON.parse(event.data);
			if (data.type === "state" && statusEl) statusEl.textContent = describeSnapshot(data.snapshot);
			if (data.type === "complete") {
				evtSource.close();
				notice.classList.remove("callout--busy");
				notice.classList.add("callout--complete");
				if (statusEl) statusEl.textContent = "Done! Reloading…";
				setTimeout(() => location.reload(), 500);
			}
			if (data.type === "error") {
				evtSource.close();
				notice.classList.remove("callout--busy");
				notice.classList.add("callout--error");
				if (statusEl) statusEl.textContent = `Error: ${data.error || "Unknown error"}`;
			}
		};
		evtSource.onerror = () => evtSource.close();
	}
</script>
