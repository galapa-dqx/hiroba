---
import Layout from "../../../layouts/Layout.astro";
import ArticleList from "../../../components/ArticleList.astro";
import BackLink from "../../../components/BackLink.astro";
import Pagination from "../../../components/Pagination.astro";
import PanelSection from "../../../components/PanelSection.astro";
import { createDb, getNewsItems, type LocalizedNewsItem } from "@hiroba/db";
import { CATEGORIES, CATEGORY_LABELS, type Category } from "@hiroba/shared";
import { maybeTriggerTitleBackfill } from "../../../lib/workflow";

// Validated against the whitelist by the middleware.
const lang = Astro.params.lang!;
const { slug } = Astro.params;

if (!slug || !CATEGORIES.includes(slug as Category)) {
	return Astro.redirect(`/${lang}`);
}

const category = slug as Category;
const cursor = Astro.url.searchParams.get("cursor") ?? undefined;

const runtime = Astro.locals.runtime;
const db = createDb(runtime.env.DB);

let items: LocalizedNewsItem[] = [];
let hasMore = false;
let nextCursor: string | undefined;

try {
	const result = await getNewsItems(db, { category, limit: 20, cursor, language: lang });
	items = result.items;
	hasMore = result.hasMore;
	nextCursor = result.nextCursor;
	// If this language is meaningfully behind on titles, backfill the archive.
	maybeTriggerTitleBackfill(runtime, lang, items);
} catch {
	// Show empty list on error
}

const categoryLabel = CATEGORY_LABELS[category];
---

<Layout title={categoryLabel} category={category}>
	<div data-cat={category}>
		<PanelSection title={categoryLabel} category={category}>
			<ArticleList items={items} hrefBase={`/${lang}/news`} />
		</PanelSection>

		<Pagination
			baseUrl={`/${lang}/category/${category}`}
			cursor={cursor}
			hasMore={hasMore}
			nextCursor={nextCursor}
		/>

		<BackLink href={`/${lang}`} label="Back to home" />
	</div>
</Layout>
