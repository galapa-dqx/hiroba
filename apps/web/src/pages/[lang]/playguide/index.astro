---
import Layout from "../../../layouts/Layout.astro";
import ArticleList from "../../../components/ArticleList.astro";
import BackLink from "../../../components/BackLink.astro";
import PanelSection from "../../../components/PanelSection.astro";
import * as Sentry from "@sentry/cloudflare";
import { createDb, getPlayguides, type LocalizedPlayguide } from "@hiroba/db";
import { maybeTriggerTitleBackfill } from "../../../lib/workflow";
import { useTranslations } from "../../../i18n";

// Validated against the whitelist by the middleware.
const lang = Astro.params.lang!;
const t = useTranslations(lang);

const runtime = Astro.locals.runtime;
const db = createDb(runtime.env.DB);

let items: LocalizedPlayguide[] = [];

try {
	// The guide set is small and bounded (~100–150 pages), so it isn't paginated.
	items = await getPlayguides(db, { language: lang });
	// If this language is meaningfully behind on titles, backfill the archive.
	maybeTriggerTitleBackfill(runtime, lang, items);
} catch (err) {
	// Show empty list on error — surface the (previously swallowed) cause.
	console.error("playguide: getPlayguides threw", err);
	Sentry.captureException(err, { tags: { site_area: "playguide" } });
}
---

<Layout title={t("playguide.title")}>
	{/* Reuse the gilt topic identity for the guide index. */}
	<div data-cat="topic">
		<PanelSection title={t("playguide.title")}>
			<ArticleList items={items} hrefBase={`/${lang}/playguide`}>
				<p class="empty" slot="empty">
					{t("playguide.emptyPre")}<code>guide01</code>{t("playguide.emptyPost")}
				</p>
			</ArticleList>
		</PanelSection>

		<BackLink href={`/${lang}`} label={t("back.home")} />
	</div>
</Layout>
