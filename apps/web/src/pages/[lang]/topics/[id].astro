---
import { env } from "cloudflare:workers";

import ArticlePage from "../../../components/ArticlePage.astro";
import LocalTime from "../../../components/LocalTime.astro";
import { createDb, getArticleTranslations, getEventsForSource } from "@hiroba/db";
import { renderBlocks, rewriteArticleHref, type Block } from "@hiroba/richtext";
import { hydrateArticleImages } from "../../../lib/article-images";
import { resolveArticleView } from "../../../lib/article-view";
import { getItemRun, triggerWorkflow } from "../../../lib/workflow";
import { useTranslations } from "../../../i18n";

// Validated against the whitelist by the middleware.
const lang = Astro.params.lang!;
const t = useTranslations(lang);
const { id } = Astro.params;
if (!id) {
	return Astro.redirect(`/${lang}/topics`);
}

const db = createDb(env.DB);

// fetch-body creates the row, so a never-seen id is valid — no 404.
const topic = await db.query.topics.findFirst({ where: { id } });

const { title: localizedTitle, blocks: localizedBlocks, translatedAt } = await getArticleTranslations(db, "topic", id, lang);
const isTranslated = !!localizedBlocks;

// The article displays only once its pipeline has settled — translated
// content present and no run in flight (DQX-28: the gate reads the item's
// hub run, not D1 state columns). Until then the page shows the processing
// notice and the run's SSE stream drives progress + reload.
const { run, snapshot } = await getItemRun("topic", id);
const view = resolveArticleView(!!localizedTitle && !!localizedBlocks, run);

// Cache by readiness: a still-processing page is never cached (the SSE stream
// drives it), a complete article caches hard (and is purged on change), a
// settled-but-degraded one stays short so a background heal surfaces on its own.
Astro.response.headers.set("Cache-Control", view.cacheControl);

// (Re)arm the pipeline as the gate decided: `force` when a viewer is waiting
// on missing content, the throttled cooldown for background heals of
// degraded or failed settles.
if (view.trigger) {
	await triggerWorkflow("topic", id, { force: view.trigger === "force" });
}

const title = localizedTitle ?? topic?.titleJa ?? t("article.loadingTopic");
const blocks: Block[] = localizedBlocks ?? (topic?.blocksJa as Block[] | null) ?? [];

const imageSrc = await hydrateArticleImages(db, blocks, {
	isTranslated,
	language: lang,
	imageBase: env.IMAGE_BASE,
});
const contentHtml = renderBlocks(blocks, { imageSrc, linkHref: rewriteArticleHref });

// Events extracted from this topic (only meaningful once the body is shown).
const events = view.ready ? await getEventsForSource(db, "topic", id, lang) : [];
---

<ArticlePage
	title={title}
	itemType="topic"
	itemId={id}
	view={view}
	snapshot={snapshot}
	runError={run?.error}
	contentHtml={contentHtml}
	events={events}
	originalUrl={`https://hiroba.dqx.jp/sc/topics/detail/${id}/`}
	translatedAtMs={translatedAt?.epochMilliseconds}
	backHref={`/${lang}/topics`}
	backLabel={t("back.topics")}
>
	<Fragment slot="meta">
		<span class="chip">{t("article.chip.topic")}</span>
		{topic && <LocalTime epochMs={topic.publishedAt.epochMilliseconds} mode="date" />}
	</Fragment>
</ArticlePage>
