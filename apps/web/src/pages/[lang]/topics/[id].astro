---
import ArticlePage from "../../../components/ArticlePage.astro";
import LocalTime from "../../../components/LocalTime.astro";
import { computeSnapshot, createDb, getArticleTranslations, getEventsForSource, getTopic } from "@hiroba/db";
import { renderBlocks, rewriteArticleHref, type Block } from "@hiroba/richtext";
import { describeSnapshot, isSnapshotComplete, isSnapshotSettled } from "@hiroba/shared";
import { hydrateArticleImages } from "../../../lib/article-images";
import { triggerWorkflow } from "../../../lib/workflow";
import { statusStrings, useTranslations } from "../../../i18n";

// Validated against the whitelist by the middleware.
const lang = Astro.params.lang!;
const t = useTranslations(lang);
const { id } = Astro.params;
if (!id) {
	return Astro.redirect(`/${lang}/topics`);
}

const runtime = Astro.locals.runtime;
const db = createDb(runtime.env.DB);

// fetch-body creates the row, so a never-seen id is valid — no 404.
const topic = await getTopic(db, id);

const { title: localizedTitle, blocks: localizedBlocks, translatedAt } = await getArticleTranslations(db, "topic", id, lang);
const isTranslated = !!localizedBlocks;

// The article displays only once its pipeline has settled — fetched, translated,
// and every text-bearing image localized (or given up on). Until then the page
// shows the processing notice and the SSE stream drives progress + reload.
const snapshot = await computeSnapshot(db, "topic", id, lang);
const ready = isSnapshotSettled(snapshot);

// Fire the pipeline unless everything already finished cleanly — a
// degraded-but-settled article displays now and retries its failures in the
// background.
if (!isSnapshotComplete(snapshot)) {
	triggerWorkflow(runtime, "topic", id);
}

const title = localizedTitle ?? topic?.titleJa ?? t("article.loadingTopic");
const blocks: Block[] = localizedBlocks ?? (topic?.blocksJa as Block[] | null) ?? [];

const imageSrc = await hydrateArticleImages(db, blocks, {
	isTranslated,
	language: lang,
	imageBase: runtime.env.IMAGE_BASE,
});
const contentHtml = renderBlocks(blocks, { imageSrc, linkHref: rewriteArticleHref });

// Events extracted from this topic (only meaningful once the body is shown).
const events = ready ? await getEventsForSource(db, "topic", id, lang) : [];
---

<ArticlePage
	title={title}
	itemType="topic"
	itemId={id}
	ready={ready}
	statusText={describeSnapshot(snapshot, statusStrings(lang))}
	contentHtml={contentHtml}
	events={events}
	originalUrl={`https://hiroba.dqx.jp/sc/topics/detail/${id}/`}
	translatedAtMs={translatedAt?.epochMilliseconds}
	backHref={`/${lang}/topics`}
	backLabel={t("back.topics")}
>
	<Fragment slot="meta">
		<span class="chip">{t("article.chip.topic")}</span>
		{topic && <LocalTime epochMs={topic.publishedAt.epochMilliseconds} mode="date" />}
	</Fragment>
</ArticlePage>
