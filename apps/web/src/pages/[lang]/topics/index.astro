---
import { env } from "cloudflare:workers";

import Layout from "../../../layouts/Layout.astro";
import ArticleList from "../../../components/ArticleList.astro";
import BackLink from "../../../components/BackLink.astro";
import Pagination from "../../../components/Pagination.astro";
import PanelSection from "../../../components/PanelSection.astro";
import * as Sentry from "@sentry/cloudflare";
import { Temporal } from "temporal-polyfill";
import { createDb, withLocalizedTitle, type LocalizedTopic } from "@hiroba/db";
import { maybeTriggerTitleBackfill } from "../../../lib/workflow";
import { useTranslations } from "../../../i18n";

// Validated against the whitelist by the middleware.
const lang = Astro.params.lang!;
const t = useTranslations(lang);
const cursor = Astro.url.searchParams.get("cursor") ?? undefined;

const db = createDb(env.DB);

let items: LocalizedTopic[] = [];
let hasMore = false;
let nextCursor: string | undefined;

const PAGE_SIZE = 20;

try {
	// Newest-first cursor pagination (mirrors the category list page).
	const rows = await db.query.topics.findMany({
		where: cursor
			? { publishedAt: { lt: Temporal.Instant.from(cursor) } }
			: undefined,
		with: { title: { where: { language: lang }, columns: { value: true } } },
		orderBy: { publishedAt: "desc" },
		limit: PAGE_SIZE + 1,
	});
	hasMore = rows.length > PAGE_SIZE;
	items = (hasMore ? rows.slice(0, PAGE_SIZE) : rows).map(withLocalizedTitle);
	nextCursor = hasMore ? items[items.length - 1].publishedAt.toString() : undefined;
	// If this language is meaningfully behind on titles, backfill the archive.
	await maybeTriggerTitleBackfill(lang, items);
} catch (err) {
	// Show empty list on error — surface the (previously swallowed) cause.
	console.error("topics: topic query threw", err);
	Sentry.captureException(err, { tags: { site_area: "topics" } });
}

---

<Layout title={t("topics.title")}>
	{/* Gilt identity, distinct from the four news categories. */}
	<div data-cat="topic">
		<PanelSection title={t("topics.title")}>
			<ArticleList items={items} hrefBase={`/${lang}/topics`}>
				<p class="empty" slot="empty">
					{t("topics.emptyPre")}<code>/{lang}/topics/&lt;id&gt;</code>{t("topics.emptyPost")}
				</p>
			</ArticleList>
		</PanelSection>

		<Pagination baseUrl={`/${lang}/topics`} cursor={cursor} hasMore={hasMore} nextCursor={nextCursor} />

		<BackLink href={`/${lang}`} label={t("back.home")} />
	</div>
</Layout>
