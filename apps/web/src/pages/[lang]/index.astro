---
import { env } from "cloudflare:workers";
import Layout from "../../layouts/Layout.astro";
import ArticleList from "../../components/ArticleList.astro";
import BannerCarousel from "../../components/BannerCarousel.astro";
import PanelSection from "../../components/PanelSection.astro";
import Ornament from "@hiroba/ui/Ornament.astro";
import * as Sentry from "@sentry/cloudflare";
import { createDb, getNewsItems } from "@hiroba/db";
import { CATEGORIES } from "@hiroba/shared";
import { maybeTriggerTitleBackfill } from "../../lib/workflow";
import { resolveBanners } from "../../lib/banners";
import { categoryLabel, useTranslations } from "../../i18n";

// Validated against the whitelist by the middleware.
const lang = Astro.params.lang!;
const t = useTranslations(lang);

const db = createDb(env.DB);

// Localized rotation banners for the top-of-page carousel. Best-effort — a
// failure here never takes down the home page.
const banners = await resolveBanners(db, {
	language: lang,
	imageBase: env.IMAGE_BASE,
}).catch(() => []);

const newsByCategory = await Promise.all(
	CATEGORIES.map(async (category) => {
		try {
			const { items } = await getNewsItems(db, { category, limit: 5, language: lang });
			return { category, items };
		} catch (err) {
			console.error(`home: getNewsItems(${category}) threw`, err);
			Sentry.captureException(err, { tags: { site_area: "home", category } });
			return { category, items: [] };
		}
	})
);

// If this language is meaningfully behind on titles, backfill the archive
// (counted across the whole home page's items).
maybeTriggerTitleBackfill(
	lang,
	newsByCategory.flatMap(({ items }) => items),
);

---

<Layout title={t("home.title")}>
	<BannerCarousel banners={banners} />

	<section class="home-hero">
		<h1>Galapa&nbsp;News</h1>
		<p class="subtitle">{t("home.heroSubtitle")}</p>
		<Ornament class="home-hero__rule" />
	</section>

	<div class="stack">
		{
			newsByCategory.map(({ category, items }) => (
				<PanelSection
					title={categoryLabel(lang, category)}
					titleHref={`/${lang}/category/${category}`}
					moreHref={`/${lang}/category/${category}`}
					category={category}
				>
					<ArticleList items={items} hrefBase={`/${lang}/news`} />
				</PanelSection>
			))
		}
	</div>
</Layout>

<style>
	.home-hero {
		text-align: center;
		margin-bottom: 1.8rem;
	}
	.home-hero h1 {
		font-size: clamp(2rem, 1.4rem + 3vw, 3rem);
	}
	.home-hero .subtitle {
		max-width: 46ch;
		margin-inline: auto;
	}
	.home-hero__rule {
		margin-top: 1.3rem;
	}
</style>
