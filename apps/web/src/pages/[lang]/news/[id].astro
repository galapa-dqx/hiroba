---
import { env } from "cloudflare:workers";

import ArticlePage from "../../../components/ArticlePage.astro";
import LocalTime from "../../../components/LocalTime.astro";
import CategoryDot from "@hiroba/ui/CategoryDot.astro";
import { createDb, getArticleTranslations, getEventsForSource, getNewsItem } from "@hiroba/db";
import { renderBlocks, rewriteArticleHref, type Block } from "@hiroba/richtext";
import type { Category } from "@hiroba/shared";
import { hydrateArticleImages } from "../../../lib/article-images";
import { resolveArticleView } from "../../../lib/article-view";
import { getItemRun, triggerWorkflow } from "../../../lib/workflow";
import { CACHE_NONE } from "../../../lib/cache";
import { categoryLabel, useTranslations } from "../../../i18n";

// Validated against the whitelist by the middleware.
const lang = Astro.params.lang!;
const t = useTranslations(lang);
const { id } = Astro.params;
if (!id) {
	return Astro.redirect(`/${lang}`);
}

const db = createDb(env.DB);

// News items are seeded by list scraping, so an unknown id is a real 404
// (unlike topics, which are fetched on first view).
const item = await getNewsItem(db, id);
if (!item) {
	return new Response("Not found", {
		status: 404,
		headers: { "Cache-Control": CACHE_NONE },
	});
}

const { title: localizedTitle, blocks: localizedBlocks, translatedAt } = await getArticleTranslations(db, "news", id, lang);
const isTranslated = !!localizedBlocks;

// The article displays only once its pipeline has settled — translated
// content present and no run in flight (DQX-28: the gate reads the item's
// hub run, not D1 state columns). Until then the page shows the processing
// notice and the run's SSE stream drives progress + reload.
const { run, snapshot } = await getItemRun("news", id);
const view = resolveArticleView(!!localizedTitle && !!localizedBlocks, run);

// Cache by readiness: a still-processing page is never cached (the SSE stream
// drives it), a complete article caches hard (and is purged on change), a
// settled-but-degraded one stays short so a background heal surfaces on its own.
Astro.response.headers.set("Cache-Control", view.cacheControl);

// (Re)arm the pipeline as the gate decided: `force` when a viewer is waiting
// on missing content, the throttled cooldown for background heals of
// degraded or failed settles.
if (view.trigger) {
	triggerWorkflow("news", id, { force: view.trigger === "force" });
}

const title = localizedTitle ?? item.titleJa;
const blocks: Block[] = localizedBlocks ?? (item.blocksJa as Block[] | null) ?? [];

const imageSrc = await hydrateArticleImages(db, blocks, {
	isTranslated,
	language: lang,
	imageBase: env.IMAGE_BASE,
});
const contentHtml = renderBlocks(blocks, { imageSrc, linkHref: rewriteArticleHref });

// Events extracted from this article (only meaningful once the body is shown).
const events = view.ready ? await getEventsForSource(db, "news", id, lang) : [];

const category = item.category as Category;
const label = categoryLabel(lang, category);
---

<ArticlePage
	title={title}
	category={category}
	itemType="news"
	itemId={id}
	view={view}
	snapshot={snapshot}
	runError={run?.error}
	contentHtml={contentHtml}
	events={events}
	originalUrl={`https://hiroba.dqx.jp/sc/news/detail/${id}/`}
	translatedAtMs={translatedAt?.epochMilliseconds}
	backHref={`/${lang}`}
	backLabel={t("back.home")}
>
	<Fragment slot="meta">
		<a href={`/${lang}/category/${category}`} class="chip"><CategoryDot category={category} />{label}</a>
		<LocalTime epochMs={item.publishedAt.epochMilliseconds} />
	</Fragment>
</ArticlePage>
