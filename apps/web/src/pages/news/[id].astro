---
import Layout from "../../layouts/Layout.astro";
import Rosette from "@hiroba/ui/Rosette.astro";
import Ornament from "@hiroba/ui/Ornament.astro";
import CategoryDot from "@hiroba/ui/CategoryDot.astro";
import { createDb, getNewsItem, translations as translationsTable } from "@hiroba/db";
import { renderBlocks, type Block } from "@hiroba/richtext";
import { CATEGORY_LABELS, type Category } from "@hiroba/shared";
import { and, eq } from "drizzle-orm";

const { id } = Astro.params;

if (!id) {
	return Astro.redirect("/");
}

const runtime = Astro.locals.runtime;
const db = createDb(runtime.env.DB);

// Get the news item metadata from D1
const item = await getNewsItem(db, id);
if (!item) {
	return new Response("Not found", { status: 404 });
}

// Check for existing translations
const existingTranslations = await db
	.select()
	.from(translationsTable)
	.where(
		and(
			eq(translationsTable.itemType, "news"),
			eq(translationsTable.itemId, id),
			eq(translationsTable.language, "en"),
		),
	)
	.all();

const titleTranslation = existingTranslations.find((t) => t.field === "title");
const contentTranslation = existingTranslations.find((t) => t.field === "content");

// Determine content state. A translations row exists from the moment the
// pipeline touches it — only state='done' means finished (a running
// re-translation may still carry a usable stale value for display below).
const hasTranslations = titleTranslation?.state === "done";
const hasContent = !!item.blocksJa;

// If no content or unfinished translations, trigger workflow (fire and forget;
// the DO ignores the trigger when a run is already in flight).
if (!hasContent || !hasTranslations) {
	try {
		const doId = runtime.env.WORKFLOW_MANAGER.idFromName(id);
		const stub = runtime.env.WORKFLOW_MANAGER.get(doId);

		stub.fetch("http://internal/trigger", {
			method: "POST",
			body: JSON.stringify({ itemId: id }),
			headers: { "Content-Type": "application/json" },
		});
	} catch (error) {
		console.error(`Workflow trigger failed for ${id}:`, error);
	}
}

// Use translations if available, otherwise fall back to Japanese. The value
// may be a stale one from before an in-flight re-translation — still the best
// thing to render.
const title = titleTranslation?.value ?? item.titleJa;

// The EN content translation stores the block tree as JSON (same format as
// topics); fall back to the Japanese blocks_ja when it's missing or unparseable.
let enBlocks: Block[] | null = null;
if (contentTranslation?.value) {
	try {
		enBlocks = JSON.parse(contentTranslation.value) as Block[];
	} catch {
		enBlocks = null;
	}
}
const blocks: Block[] = enBlocks ?? (item.blocksJa as Block[] | null) ?? [];
const contentHtml = renderBlocks(blocks);
const translatedAt = titleTranslation?.translatedAt ?? null;
const isTranslated = !!titleTranslation?.value;
const category = item.category as Category;
const categoryLabel = CATEGORY_LABELS[category] || item.category;
---

<Layout title={title} category={category}>
	<article data-cat={item.category}>
		<header class="article-header">
			<div class="meta">
				<a href={`/category/${item.category}`} class="chip"><CategoryDot category={category} />{categoryLabel}</a>
				<time datetime={item.publishedAt.toString()}>
					<script define:vars={{ publishedAt: item.publishedAt.epochMilliseconds }}>
						const timeEl = document.currentScript.parentElement;
						timeEl.textContent = new Date(publishedAt).toLocaleString("en-US", {
							year: "numeric",
							month: "long",
							day: "numeric",
							hour: "numeric",
							minute: "2-digit",
						});
					</script>
				</time>
			</div>
			<h1 class="article-title">{title}</h1>
		</header>

		{(!hasContent || !isTranslated) && (
			<div class="callout callout--busy" id="processing-notice" data-item-id={id} role="status">
				<Rosette class="callout__glyph" />
				<p id="processing-status">
					{!hasContent ? "Fetching content…" : "Translating…"}
				</p>
			</div>
		)}

		{contentHtml && (
			<div class="scroll">
				<div class="scroll__content news-body" set:html={contentHtml} />
			</div>
		)}

		{translatedAt && (
			<footer class="translation-info">
				<Ornament />
				<p>
					Translated on {new Date(translatedAt.epochMilliseconds).toLocaleDateString("en-US", {
						year: "numeric",
						month: "long",
						day: "numeric",
					})}
				</p>
				<a
					class="pill pill--ghost"
					href={`https://hiroba.dqx.jp/sc/news/detail/${id}/`}
					target="_blank"
					rel="noopener noreferrer">View original article ↗</a
				>
			</footer>
		)}

		<nav class="back-link">
			<a href="/" class="pill pill--ghost">‹ Back to home</a>
		</nav>
	</article>
</Layout>

<style>
	.article-header {
		margin-bottom: 1.4rem;
	}
	.article-title {
		font-size: clamp(1.7rem, 1.25rem + 2.4vw, 2.5rem);
		line-height: 1.22;
	}
	.callout {
		margin-bottom: 1.5rem;
	}
	.translation-info {
		margin-top: 2.4rem;
		text-align: center;
		color: var(--ink-faint);
		font-size: 0.9rem;
	}
	.translation-info p {
		margin: 1rem 0;
	}
</style>

{/* The rendered block tree is injected via set:html, so its rt-* styles must be
    global. News bodies are paragraphs + links, but we cover the common blocks. */}
<style is:global>
	/* Structured HTML (not the old preformatted plaintext) — collapse whitespace. */
	.news-body {
		white-space: normal;
	}
	.news-body > * + * {
		margin-top: 1rem;
	}
	.news-body img {
		max-width: 100%;
		height: auto;
	}
	.news-body h2,
	.news-body h3 {
		font-family: var(--font-display);
		line-height: 1.3;
		margin-top: 1.5rem;
	}

	/* table → ruled ledger */
	.news-body .rt-table {
		border-collapse: collapse;
		width: 100%;
		font-size: 0.94em;
	}
	.news-body .rt-table td,
	.news-body .rt-table th {
		border: 1px solid var(--rule);
		padding: 0.45rem 0.65rem;
		text-align: left;
	}
	.news-body .rt-table th {
		background: var(--surface-sunken);
		font-weight: 650;
	}

	/* badge → red chip */
	.news-body .rt-badge {
		display: inline-block;
		margin-left: 0.3em;
		padding: 0.08em 0.45em;
		font-size: 0.72em;
		font-weight: 800;
		letter-spacing: 0.04em;
		color: oklch(99% 0.01 30);
		background: linear-gradient(180deg, var(--red-9), var(--red-10));
		border-radius: var(--radius);
	}

	.news-body .rt-icon {
		display: inline;
		height: 1em;
		vertical-align: -0.12em;
	}
</style>

<script>
	import { describeSnapshot } from "@hiroba/shared";

	const notice = document.getElementById("processing-notice");
	if (notice) {
		const itemId = notice.dataset.itemId;
		const statusEl = document.getElementById("processing-status");

		const evtSource = new EventSource(`/api/news/${itemId}/sse`);

		evtSource.onmessage = (event) => {
			const data = JSON.parse(event.data);

			if (data.type === "state" && statusEl) {
				statusEl.textContent = describeSnapshot(data.snapshot);
			}

			if (data.type === "complete") {
				evtSource.close();
				notice.classList.remove("callout--busy");
				notice.classList.add("callout--complete");
				if (statusEl) statusEl.textContent = "Done! Reloading…";
				setTimeout(() => location.reload(), 500);
			}

			if (data.type === "error") {
				evtSource.close();
				notice.classList.remove("callout--busy");
				notice.classList.add("callout--error");
				if (statusEl) statusEl.textContent = `Error: ${data.error || "Unknown error"}`;
			}
		};

		evtSource.onerror = () => {
			evtSource.close();
		};
	}
</script>
