---
import Layout from "../../layouts/Layout.astro";
import Rosette from "@hiroba/ui/Rosette.astro";
import Ornament from "@hiroba/ui/Ornament.astro";
import CategoryDot from "@hiroba/ui/CategoryDot.astro";
import EventsRail from "../../components/EventsRail.astro";
import { createDb, getEventsForSource, getNewsItem, translations as translationsTable } from "@hiroba/db";
import { renderBlocks, type Block } from "@hiroba/richtext";
import { CATEGORY_LABELS, type Category } from "@hiroba/shared";
import { and, eq } from "drizzle-orm";

const { id } = Astro.params;

if (!id) {
	return Astro.redirect("/");
}

const runtime = Astro.locals.runtime;
const db = createDb(runtime.env.DB);

// Get the news item metadata from D1
const item = await getNewsItem(db, id);
if (!item) {
	return new Response("Not found", { status: 404 });
}

// Check for existing translations
const existingTranslations = await db
	.select()
	.from(translationsTable)
	.where(
		and(
			eq(translationsTable.itemType, "news"),
			eq(translationsTable.itemId, id),
			eq(translationsTable.language, "en"),
		),
	)
	.all();

const titleTranslation = existingTranslations.find((t) => t.field === "title");
const contentTranslation = existingTranslations.find((t) => t.field === "content");

// Determine content state. A translations row exists from the moment the
// pipeline touches it — only state='done' means finished (a running
// re-translation may still carry a usable stale value for display below).
const hasTranslations = titleTranslation?.state === "done";
const hasContent = !!item.blocksJa;

// If no content or unfinished translations, trigger workflow (fire and forget;
// the DO ignores the trigger when a run is already in flight).
if (!hasContent || !hasTranslations) {
	try {
		const doId = runtime.env.WORKFLOW_MANAGER.idFromName(id);
		const stub = runtime.env.WORKFLOW_MANAGER.get(doId);

		stub.fetch("http://internal/trigger", {
			method: "POST",
			body: JSON.stringify({ itemId: id }),
			headers: { "Content-Type": "application/json" },
		});
	} catch (error) {
		console.error(`Workflow trigger failed for ${id}:`, error);
	}
}

// Use translations if available, otherwise fall back to Japanese. The value
// may be a stale one from before an in-flight re-translation — still the best
// thing to render.
const title = titleTranslation?.value ?? item.titleJa;

// The EN content translation stores the block tree as JSON (same format as
// topics); fall back to the Japanese blocks_ja when it's missing or unparseable.
let enBlocks: Block[] | null = null;
if (contentTranslation?.value) {
	try {
		enBlocks = JSON.parse(contentTranslation.value) as Block[];
	} catch {
		enBlocks = null;
	}
}
const blocks: Block[] = enBlocks ?? (item.blocksJa as Block[] | null) ?? [];
const contentHtml = renderBlocks(blocks);

// Events extracted from this article (only present once its body was fetched).
const events = hasContent ? await getEventsForSource(db, "news", id, "en") : [];
const translatedAt = titleTranslation?.translatedAt ?? null;
const isTranslated = !!titleTranslation?.value;
const category = item.category as Category;
const categoryLabel = CATEGORY_LABELS[category] || item.category;
---

<Layout title={title} category={category}>
	<article data-cat={item.category}>
		<header class="article-header">
			<div class="meta">
				<a href={`/category/${item.category}`} class="chip"><CategoryDot category={category} />{categoryLabel}</a>
				<time datetime={item.publishedAt.toString()}>
					<script define:vars={{ publishedAt: item.publishedAt.epochMilliseconds }}>
						const timeEl = document.currentScript.parentElement;
						timeEl.textContent = new Date(publishedAt).toLocaleString("en-US", {
							year: "numeric",
							month: "long",
							day: "numeric",
							hour: "numeric",
							minute: "2-digit",
						});
					</script>
				</time>
			</div>
			<h1 class="article-title">{title}</h1>
		</header>

		{(!hasContent || !isTranslated) && (
			<div class="callout callout--busy" id="processing-notice" data-item-id={id} role="status">
				<Rosette class="callout__glyph" />
				<p id="processing-status">
					{!hasContent ? "Fetching content…" : "Translating…"}
				</p>
			</div>
		)}

		{contentHtml && (
			<div class="article-grid">
				<div class="scroll">
					<div class="scroll__content news-body" set:html={contentHtml} />
				</div>
				<EventsRail events={events} />
			</div>
		)}

		{translatedAt && (
			<footer class="translation-info">
				<Ornament />
				<p>
					Translated on {new Date(translatedAt.epochMilliseconds).toLocaleDateString("en-US", {
						year: "numeric",
						month: "long",
						day: "numeric",
					})}
				</p>
				<a
					class="pill pill--ghost"
					href={`https://hiroba.dqx.jp/sc/news/detail/${id}/`}
					target="_blank"
					rel="noopener noreferrer">View original article ↗</a
				>
			</footer>
		)}

		<nav class="back-link">
			<a href="/" class="pill pill--ghost">‹ Back to home</a>
		</nav>
	</article>
</Layout>

<style>
	.article-header {
		margin-bottom: 1.4rem;
	}
	.article-title {
		font-size: clamp(1.7rem, 1.25rem + 2.4vw, 2.5rem);
		line-height: 1.22;
	}
	.callout {
		margin-bottom: 1.5rem;
	}
	/* article body with the events panel stacked full-width beneath it */
	.article-grid {
		display: grid;
		gap: 1.5rem;
	}
	.translation-info {
		margin-top: 2.4rem;
		text-align: center;
		color: var(--ink-faint);
		font-size: 0.9rem;
	}
	.translation-info p {
		margin: 1rem 0;
	}
</style>

{/* The rendered block tree is injected via set:html, so its rt-* styles must be
    global. News bodies are paragraphs + links, but we cover the common blocks. */}
<style is:global>
	/* Structured HTML (not the old preformatted plaintext) — collapse whitespace. */
	.news-body {
		white-space: normal;
	}
	.news-body > * + * {
		margin-top: 1rem;
	}
	.news-body img {
		max-width: 100%;
		height: auto;
	}

	/* captioned image → centered figure with a manuscript caption beneath */
	.news-body .rt-figure {
		margin: 1.25rem auto;
		text-align: center;
	}
	.news-body .rt-caption {
		display: block;
		max-width: 46ch;
		margin: 0.55rem auto 0;
		font-size: 0.9em;
		line-height: 1.5;
		color: var(--ink-faint);
		text-wrap: balance;
	}

	/* the source's box_terms box — a gilt frame shared by the TOC nav and the
	   plain terms/spec boxes (they're the same decorative box in the source) */
	.news-body .rt-toc,
	.news-body .rt-infobox[data-variant="terms"] {
		margin: 1.5rem auto;
		padding: 0.95rem 1.25rem 1.05rem;
		background: linear-gradient(
			180deg,
			color-mix(in oklch, var(--surface-panel), var(--gold) 4%),
			color-mix(in oklch, var(--surface-sunken), var(--gold) 8%)
		);
		border: 1px solid var(--gold-edge);
		box-shadow:
			var(--inset-top),
			var(--shadow-sm),
			inset 0 0 0 3px color-mix(in oklch, var(--gold) 20%, transparent);
	}
	.news-body .rt-toc > p:first-child {
		margin: 0 0 0.65rem;
		text-align: center;
		font-family: var(--font-display);
		font-size: 1.15rem;
		font-weight: 700;
		color: var(--ink);
	}
	.news-body .rt-toc ul {
		list-style: none;
		margin: 0;
		padding: 0;
	}
	.news-body .rt-toc li {
		display: flex;
		align-items: baseline;
		gap: 0.5rem;
		padding: 0.2rem 0;
	}
	.news-body .rt-toc li::before {
		content: "";
		flex: none;
		align-self: center;
		width: 0.6em;
		height: 0.6em;
		background: linear-gradient(150deg, var(--gold-hi), var(--gold) 50%, var(--gold-edge));
		clip-path: polygon(50% 0, 100% 38%, 82% 100%, 18% 100%, 0 38%);
		filter: drop-shadow(0 1px 0.5px oklch(0% 0 0 / 0.3));
	}
	.news-body .rt-toc a {
		font-weight: 600;
	}

	/* table → ruled ledger */
	.news-body .rt-table {
		border-collapse: collapse;
		width: 100%;
		font-size: 0.94em;
	}
	.news-body .rt-table td,
	.news-body .rt-table th {
		border: 1px solid var(--rule);
		padding: 0.45rem 0.65rem;
		text-align: left;
	}
	.news-body .rt-table th {
		background: var(--surface-sunken);
		font-weight: 650;
	}

	/* headerless single-column table → a clean borderless stack (layout, not data:
	   e.g. the box_terms table of contents), so it reads as a list, not a ledger */
	.news-body .rt-table[data-variant="layout"],
	.news-body .rt-table[data-variant="layout"] tbody,
	.news-body .rt-table[data-variant="layout"] tr,
	.news-body .rt-table[data-variant="layout"] td {
		display: block;
		width: auto;
		font-size: 1rem;
	}
	.news-body .rt-table[data-variant="layout"] td {
		border: none;
		padding: 0.1rem 0;
	}
	/* tighten the airy standalone-heading spacing when items are stacked in a TOC */
	.news-body .rt-table[data-variant="layout"] :is(.rt-h-icon, h4) {
		margin-top: 0.4rem;
	}

	/* badge → red chip */
	.news-body .rt-badge {
		display: inline-block;
		margin-left: 0.3em;
		padding: 0.08em 0.45em;
		font-size: 0.72em;
		font-weight: 800;
		letter-spacing: 0.04em;
		color: oklch(99% 0.01 30);
		background: linear-gradient(180deg, var(--red-9), var(--red-10));
		border-radius: var(--radius);
	}
	/* the "Check" mark (TOC entries) → a gilt chip, not the red "New" flag */
	.news-body .rt-badge[data-variant="checkmark"] {
		color: oklch(30% 0.05 70);
		background: linear-gradient(180deg, var(--gold-hi), var(--gold-mid));
	}

	.news-body .rt-icon {
		display: inline;
		height: 1em;
		vertical-align: -0.12em;
	}

	/* workflow-inserted event annotation → subtle gilt marker; the data-event-*
	   attrs are the hook for future calendar linking */
	.news-body .rt-event {
		border-bottom: 1px dashed var(--gold-edge);
	}
	/* localized timestamps carry the original JST value in the title tooltip */
	.news-body time.rt-time[title] {
		cursor: help;
		text-decoration: underline dotted var(--gold-edge);
		text-underline-offset: 0.15em;
	}
</style>

<script>
	import { describeSnapshot } from "@hiroba/shared";
	import "../../scripts/localize-times";

	const notice = document.getElementById("processing-notice");
	if (notice) {
		const itemId = notice.dataset.itemId;
		const statusEl = document.getElementById("processing-status");

		const evtSource = new EventSource(`/api/news/${itemId}/sse`);

		evtSource.onmessage = (event) => {
			const data = JSON.parse(event.data);

			if (data.type === "state" && statusEl) {
				statusEl.textContent = describeSnapshot(data.snapshot);
			}

			if (data.type === "complete") {
				evtSource.close();
				notice.classList.remove("callout--busy");
				notice.classList.add("callout--complete");
				if (statusEl) statusEl.textContent = "Done! Reloading…";
				setTimeout(() => location.reload(), 500);
			}

			if (data.type === "error") {
				evtSource.close();
				notice.classList.remove("callout--busy");
				notice.classList.add("callout--error");
				if (statusEl) statusEl.textContent = `Error: ${data.error || "Unknown error"}`;
			}
		};

		evtSource.onerror = () => {
			evtSource.close();
		};
	}
</script>
