---
import ArticlePage from "../../components/ArticlePage.astro";
import LocalTime from "../../components/LocalTime.astro";
import CategoryDot from "@hiroba/ui/CategoryDot.astro";
import { computeSnapshot, createDb, getArticleTranslations, getEventsForSource, getNewsItem } from "@hiroba/db";
import { renderBlocks, rewriteArticleHref, type Block } from "@hiroba/richtext";
import { CATEGORY_LABELS, describeSnapshot, isSnapshotComplete, isSnapshotSettled, type Category } from "@hiroba/shared";
import { hydrateArticleImages } from "../../lib/article-images";
import { triggerWorkflow } from "../../lib/workflow";

const { id } = Astro.params;
if (!id) {
	return Astro.redirect("/");
}

const runtime = Astro.locals.runtime;
const db = createDb(runtime.env.DB);

// News items are seeded by list scraping, so an unknown id is a real 404
// (unlike topics, which are fetched on first view).
const item = await getNewsItem(db, id);
if (!item) {
	return new Response("Not found", { status: 404 });
}

const { title: enTitle, blocks: enBlocks, translatedAt } = await getArticleTranslations(db, "news", id, "en");
const isTranslated = !!enBlocks;

// The article displays only once its pipeline has settled — fetched and
// translated (news has no image steps, so its snapshot carries images: null).
// Until then the page shows the processing notice and the SSE stream drives
// progress + reload.
const snapshot = await computeSnapshot(db, "news", id, "en");
const ready = isSnapshotSettled(snapshot);

// Fire the pipeline unless everything already finished cleanly — a
// degraded-but-settled article displays now and retries its failures in the
// background.
if (!isSnapshotComplete(snapshot)) {
	triggerWorkflow(runtime, "news", id);
}

const title = enTitle ?? item.titleJa;
const blocks: Block[] = enBlocks ?? (item.blocksJa as Block[] | null) ?? [];

const imageSrc = await hydrateArticleImages(db, blocks, {
	isTranslated,
	imageBase: runtime.env.IMAGE_BASE,
});
const contentHtml = renderBlocks(blocks, { imageSrc, linkHref: rewriteArticleHref });

// Events extracted from this article (only meaningful once the body is shown).
const events = ready ? await getEventsForSource(db, "news", id, "en") : [];

const category = item.category as Category;
const categoryLabel = CATEGORY_LABELS[category] || item.category;
---

<ArticlePage
	title={title}
	category={category}
	itemType="news"
	itemId={id}
	ready={ready}
	statusText={describeSnapshot(snapshot)}
	contentHtml={contentHtml}
	events={events}
	originalUrl={`https://hiroba.dqx.jp/sc/news/detail/${id}/`}
	translatedAtMs={translatedAt?.epochMilliseconds}
	backHref="/"
	backLabel="Back to home"
>
	<Fragment slot="meta">
		<a href={`/category/${category}`} class="chip"><CategoryDot category={category} />{categoryLabel}</a>
		<LocalTime epochMs={item.publishedAt.epochMilliseconds} />
	</Fragment>
</ArticlePage>
