---
/**
 * Ornament — a horizontal divider: a faceted gilt lozenge flanked by fading
 * gold rules. Drop between sections. Pure CSS rules (from .ornament) + SVG gem.
 */
interface Props {
  class?: string;
}
const { class: className } = Astro.props;
const uid = Math.random().toString(36).slice(2, 8);
---

<div class:list={['ornament', className]} role="separator" aria-hidden="true">
  <svg viewBox="0 0 32 32" fill="none">
    <defs>
      <linearGradient id={`lz-${uid}`} x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%" stop-color="var(--gold-hi)"></stop>
        <stop offset="55%" stop-color="var(--gold)"></stop>
        <stop offset="100%" stop-color="var(--gold-edge)"></stop>
      </linearGradient>
    </defs>
    <!-- outer lozenge -->
    <path d="M16 2 L27 16 L16 30 L5 16 Z" fill={`url(#lz-${uid})`} stroke="var(--gold-edge)" stroke-width="0.75" stroke-linejoin="round"></path>
    <!-- facet lines -->
    <path d="M16 2 L16 30 M5 16 L27 16 M16 2 L5 16 L16 30 L27 16 Z" stroke="var(--gold-edge)" stroke-width="0.5" opacity="0.5"></path>
    <!-- inner gem -->
    <path d="M16 9 L21 16 L16 23 L11 16 Z" fill="var(--gold-hi)" opacity="0.55"></path>
  </svg>
</div>
